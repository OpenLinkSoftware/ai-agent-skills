@prefix : <#> .
@prefix schema: <http://schema.org/> .
@prefix sc: <https://github.com/OpenLinkSoftware/ai-agent-skills/tree/main/screencast-recorder/ontology#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

:storyboard a schema:HowTo ;
  schema:name "Server Demo Screencast"@en ;
  schema:url <http://localhost:8765/> ;
  schema:result [
    a schema:VideoObject ;
    schema:name "server-demo.webm"@en ;
    schema:encodingFormat "video/webm"
  ] ;
  sc:viewportWidth 1440 ;
  sc:viewportHeight 900 ;
  sc:cursorVisible true ;
  sc:cursorClicks true ;
  sc:cursorColor "#1a73e8" ;
  sc:pythonCode """
from pathlib import Path
root = Path("/tmp/screencast-demo")
root.mkdir(parents=True, exist_ok=True)
(root / "index.html").write_text(
  "<html><body><h1>Demo App</h1><p>Prepared for screencast.</p></body></html>"
)
""" ;
  sc:serverCommand "python3 -m http.server 8765 --directory /tmp/screencast-demo" ;
  schema:step :scene-1, :scene-2 .

:scene-1 a schema:HowToStep ;
  schema:position 1 ;
  schema:name "App loads from local server"@en ;
  schema:direction [
    a sc:PauseAction ;
    sc:pauseDuration 2.0
  ] .

:scene-2 a schema:HowToStep ;
  schema:position 2 ;
  schema:name "Interact with the demo"@en ;
  schema:direction [
    a schema:ClickAction ;
    sc:selector "a"
  ], [
    a sc:WaitForAction ;
    sc:selector "body"
  ], [
    a sc:PauseAction ;
    sc:pauseDuration 2.0
  ] .
