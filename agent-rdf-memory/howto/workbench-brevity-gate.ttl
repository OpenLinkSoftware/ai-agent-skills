@prefix :       <#> .
@prefix schema: <http://schema.org/> .
@prefix rdfs:   <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd:    <http://www.w3.org/2001/XMLSchema#> .
@prefix onto:   <https://www.openlinksw.com/ontology/> .

<> a schema:CreativeWork ;
    schema:name "HowTo: Workbench Brevity Gate for HTML Infographics"@en ;
    schema:description "Prevents technical workbench sections, especially footer SPARQL workbenches, from accumulating redundant headings, explanatory text, duplicate previews, and repeated format guidance."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime ;
    schema:dateModified "2026-07-14T00:00:00Z"^^xsd:dateTime ;
    schema:author <https://linkedin.com/in/kidehen#this> ;
    schema:about :HowToWorkbenchBrevityGate .

:HowToWorkbenchBrevityGate a schema:HowTo ;
    schema:name "Workbench Brevity Gate"@en ;
    schema:description "Technical zones may use technical vocabulary, but they must stay compact and task-oriented. Do not repeat the same concept through stacked labels, explanatory paragraphs, duplicated query previews, and redundant format notes."@en ;
    schema:step :stepSinglePurposeTitle,
                :stepNoDuplicateGuidance,
                :stepControlsCarryMeaning,
                :stepPreDeliveryWorkbenchScan .

:stepSinglePurposeTitle a schema:HowToStep ;
    schema:position 1 ;
    schema:name "Use one clear title for each workbench"@en ;
    schema:text "A technical workbench should have one concise title such as 'SPARQL Workbench'. Avoid stacked labels like a kicker plus a long heading plus an explanatory subtitle when the controls already reveal the purpose."@en .

:stepNoDuplicateGuidance a schema:HowToStep ;
    schema:position 2 ;
    schema:name "Do not duplicate instructions already present in controls or content"@en ;
    schema:text "Do not repeat format guidance, endpoint purpose, recipe intent, or query text in multiple visible places. If a textarea already contains the query, do not also show a second visible static query preview unless the user explicitly asks for a read-only preview."@en .

:stepControlsCarryMeaning a schema:HowToStep ;
    schema:position 3 ;
    schema:name "Let controls carry ordinary workbench meaning"@en ;
    schema:text "Use labels, selectors, buttons, and status text for operational meaning. Prefer a compact field group plus action row over prose explaining what each control does. Keep required harness IDs and links, but hide or remove nonessential duplicate presentation."@en .

:stepPreDeliveryWorkbenchScan a schema:HowToStep ;
    schema:position 4 ;
    schema:name "Scan SPARQL and technical workbenches for redundancy before delivery"@en ;
    schema:text "Before delivering an HTML infographic, inspect every SPARQL, query, KG settings, or technical workbench section for stacked labels, repeated instructions, duplicate previews, and explanatory paragraphs that do not change the user's next action. Reduce to the minimum controls required for the task and harness contract."@en ;
    onto:hasTrigger onto:triggerArtifactGeneration, onto:triggerBehaviorGapIdentified .
