@prefix : <#> .
@prefix schema: <http://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .

<> a schema:HowTo ;
    schema:name "Ontology Cross-Reference Gate"@en ;
    schema:description "Requirements for custom ontology terms in generated RDF: mandatory rdfs:label, rdfs:comment, rdfs:domain/range for properties, and at least one verified external cross-reference to schema.org, DBpedia, or Wikidata. Why this gate exists: in session 2026-06-13, a custom ontology was generated where (a) properties lacked rdfs:domain and rdfs:range, (b) only the ontology entity had annotations — individual classes and properties relied on schema:name alone, and (c) zero external cross-references existed. This gate ensures every ontology term is fully described, properly constrained, and semantically aligned with the broader vocabulary ecosystem."@en ;
    schema:dateCreated "2026-06-25T00:00:00Z"^^xsd:dateTime ;
    schema:dateModified "2026-07-18T00:00:00Z"^^xsd:dateTime ;
    schema:author <https://linkedin.com/in/kidehen#this> ;
    schema:step :step-annotations, :step-domainRange, :step-externalCrossReferences,
        :step-gateEnforcement ;
    schema:workExample :workExample-crossReferencedTerms ;
    rdfs:seeAlso <../preferences.ttl#step-ontologyCrossReference> .

# ── Step 1: Annotations ──────────────────────────────────────────────────────

:step-annotations a schema:HowToStep ;
    schema:position "1"^^xsd:integer ;
    schema:name "Annotate every custom term with rdfs:label and rdfs:comment"@en ;
    schema:text "Every custom class and property MUST carry rdfs:label (human-readable name) and rdfs:comment (description) alongside its type declaration. The ontology entity itself MUST have schema:name, schema:description, rdfs:label, and rdfs:comment."@en .

# ── Step 2: Domain and Range ─────────────────────────────────────────────────

:step-domainRange a schema:HowToStep ;
    schema:position "2"^^xsd:integer ;
    schema:name "Declare rdfs:domain and rdfs:range on every custom property"@en ;
    schema:text "Every custom property (rdf:Property) MUST declare rdfs:domain and rdfs:range. The domain MUST be the most specific custom class available — never default to schema:Thing when a custom class from the same ontology fits. The range MUST be the most specific type (xsd:string, xsd:integer, or a custom class where applicable). Neither may be omitted or defaulted."@en .

# ── Step 3: External Cross-References ────────────────────────────────────────

:step-externalCrossReferences a schema:HowToStep ;
    schema:position "3"^^xsd:integer ;
    schema:name "Cross-reference every custom term against schema.org, DBpedia, and Wikidata"@en ;
    schema:text """For custom classes (rdfs:Class):
1. Search schema.org for an owl:equivalentClass or rdfs:subClassOf match.
2. Search DBpedia for the closest class resource via owl:equivalentClass or rdfs:seeAlso.
3. Search Wikidata for the closest class entity (Q-item) via rdfs:seeAlso.

For custom properties (rdf:Property):
1. Search schema.org for an owl:equivalentProperty match.
2. Search DBpedia for the closest property or ontology term via rdfs:subPropertyOf or rdfs:seeAlso.
3. Search Wikidata for the closest property (P-item) via rdfs:seeAlso.

Every cross-reference IRI MUST be verified before use — a guessed or fabricated schema.org/DBpedia/Wikidata URI is a contract violation. If no shared vocabulary term exists at an appropriate semantic distance, document the gap in rdfs:comment rather than leaving the term isolated."""@en ;
    rdfs:seeAlso <../preferences.ttl#step-externalIriVerification>,
        <external-iri-verification.ttl> .

# ── Step 4: Gate Enforcement ─────────────────────────────────────────────────

:step-gateEnforcement a schema:HowToStep ;
    schema:position "4"^^xsd:integer ;
    schema:name "Enforce the gate before emitting generated RDF"@en ;
    schema:text """Every custom class and property in the generated RDF MUST have: (a) rdfs:label + rdfs:comment; (b) rdfs:domain + rdfs:range (properties only); (c) at least one external cross-reference — unless explicitly waived by the user (elicit this waiver; never assume it — see elicit-before-conditional-default.ttl).

rdfs:isDefinedBy MUST point to the document-local ontology entity. External cross-references complement, not replace, this annotation."""@en ;
    rdfs:seeAlso <elicit-before-conditional-default.ttl> .

# ── Worked Example ───────────────────────────────────────────────────────────

:workExample-crossReferencedTerms a schema:CreativeWork ;
    schema:name "Fully gated custom class and property"@en ;
    schema:text """:StartupEra a rdfs:Class ;
    rdfs:label "Startup Era"@en ;
    rdfs:comment "An era of startup formation characterized by a dominant technological paradigm."@en ;
    rdfs:subClassOf schema:Thing ;
    rdfs:isDefinedBy :analysisOntology ;
    rdfs:seeAlso <http://dbpedia.org/resource/Business_cycle> .

:hasTechnologistAdvantage a rdf:Property ;
    rdfs:label "has technologist advantage"@en ;
    rdfs:comment "Structural leverage technologists have over non-technologists in a given era."@en ;
    rdfs:domain :StartupEra ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy :analysisOntology ;
    rdfs:seeAlso <http://dbpedia.org/resource/Skill_(labor)> ."""@en .
