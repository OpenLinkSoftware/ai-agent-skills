@prefix : <#> .
@prefix schema: <http://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix cert: <http://www.w3.org/ns/auth/cert#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix onto: <../ontology.ttl#> .
@prefix skills: <https://github.com/OpenLinkSoftware/ai-agent-skills/tree/main/> .

<> a schema:CreativeWork ;
    schema:about :youidValidationGates ;
    schema:name "YouID Skill — Validation Gates"@en ;
    schema:description "Standing validation gates for the youid skill, ensuring credential consistency across all identity output documents."@en ;
    schema:dateCreated "2026-06-18T13:05:00Z"^^xsd:dateTime ;
    schema:dateModified "2026-07-18T00:00:00Z"^^xsd:dateTime .

:youidValidationGates a schema:HowTo ;
    schema:name "YouID Credential Validation Procedure"@en ;
    schema:description "Post-generation and pre-deployment checks for WebID credential bundles generated by the youid skill. Historical bug that motivated the gate: on 2026-06-18, generate_certificate.sh:107 had a grep -A1 bug that captured 'X509v3extensions:' instead of the real exponent, corrupting all output files. The fix was awk '/Exponent:/ {print $2}'."@en ;
    schema:step :step-extractKeyFromPkcs12, :step-checkOutputDocuments,
        :step-exponentTypedLiteral ;
    rdfs:seeAlso <../preferences.ttl#step-youidValidationGate> .

# ── Step 1: Extract the Key From the PKCS#12 Bundle ──────────────────────────

:step-extractKeyFromPkcs12 a schema:HowToStep ;
    schema:position 1 ;
    schema:name "Extract modulus and exponent from cert.p12"@en ;
    schema:text """Extract the RSA public key components from the PKCS#12 certificate:
    openssl pkcs12 -in cert.p12 -passin pass:youid -nokeys -clcerts | openssl x509 -noout -modulus
    openssl pkcs12 -in cert.p12 -passin pass:youid -nokeys -clcerts | openssl x509 -noout -text | awk '/Exponent:/ {print $2}'

If CA/issuer certificates are in the chain, use the end-entity (leaf) cert only."""@en ;
    onto:hasTrigger onto:triggerSkillInvocation, onto:triggerArtifactGeneration ;
    schema:associatedMedia <https://github.com/OpenLinkSoftware/ai-agent-skills/tree/main/youid#this> .

# ── Step 2: Check All Output Documents ───────────────────────────────────────

:step-checkOutputDocuments a schema:HowToStep ;
    schema:position 2 ;
    schema:name "Verify modulus and exponent are consistently reflected in all three local output documents"@en ;
    schema:text """Before deploying or distributing any YouID credential bundle, search each output file for the matching modulus hex string and exponent value:
    1. index.html — cert:modulus and cert:exponent RDFa must match the cert
    2. profile.ttl — cert:modulus and cert:exponent values must match the cert
    3. profile.jsonld — cert:modulus and cert:exponent values must match the cert

All three must match. Any discrepancy means the generation script has a bug and must be fixed before deployment."""@en ;
    rdfs:seeAlso <../sessions/2026-06-18-opencode-agent-skills.ttl> .

# ── Step 3: Exponent Typed-Literal Requirement ───────────────────────────────

:step-exponentTypedLiteral a schema:HowToStep ;
    schema:position 3 ;
    schema:name "Use the \"65537\"^^xsd:int typed literal for cert:exponent in Turtle outputs"@en ;
    schema:text "The exponent in profile.ttl and public_key.ttl MUST use the \"65537\"^^xsd:int typed literal format, not bare 65537 (xsd:integer). Some SPARQL processors require strict xsd:int type matching for cert:exponent."@en .
