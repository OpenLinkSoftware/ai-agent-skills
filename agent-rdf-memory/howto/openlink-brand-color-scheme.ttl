@prefix : <#> .
@prefix schema: <http://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix onto: <../ontology.ttl#> .

<> a schema:HowTo ;
    schema:name "OpenLink Brand Color Scheme — Default Palette for RDF Infographic HTML"@en ;
    schema:description "Standing default CSS color-variable palette for HTML infographics generated by kg-generator + rdf-infographic-skill, sourced verbatim from openlinksw.com's own CSS custom properties (--opal-*, --ols-*) rather than invented. Applies going forward unless the user names a different site/brand to match for a specific document. This is a DEFAULT, not an unconditional override — a per-document brand instruction (as with the 'apply the color scheme from https://www.openlinksw.com' ask that prompted this rule) always wins for that document."@en ;
    schema:dateCreated "2026-07-13T00:00:00Z"^^xsd:dateTime ;
    schema:dateModified "2026-07-18T00:00:00Z"^^xsd:dateTime ;
    schema:author <https://linkedin.com/in/kidehen#this> ;
    schema:step :step-applyDefaultPalette, :step-provenanceRederivation,
        :step-accentSwapRationale, :step-paletteVerification ;
    schema:workExample :workExample-paletteBlocks ;
    rdfs:seeAlso <../preferences.ttl#step-openlinkBrandColorScheme> .

# ── Step 1: Apply the Default Palette ────────────────────────────────────────

:step-applyDefaultPalette a schema:HowToStep ;
    schema:position 1 ;
    schema:name "Default the :root / html[data-theme=dark] / @media(prefers-color-scheme:dark) CSS variable blocks to OpenLink's verified brand palette"@en ;
    schema:text "Effective 2026-07-13, all HTML infographics generated by kg-generator + rdf-infographic-skill (or any equivalent skill producing a CSS-variable-driven theme block matching the --bg/--panel/--panel-strong/--ink/--muted/--line/--accent/--accent2/--accent3/--chip/--shadow pattern) default to the OpenLink Software brand palette (see the worked example), instead of the prior generic blue/purple/teal placeholder palette. The dark-theme block must appear in BOTH html[data-theme=\"dark\"] AND @media(prefers-color-scheme:dark) html:not([data-theme=\"light\"]) forms, byte-identical, per the existing dark-mode-CSS rule. The existing .hero{background:linear-gradient(135deg,var(--accent),var(--accent2))} rule needs no change — it automatically becomes navy→cyan in light mode and cyan→lighter-cyan in dark mode, mirroring OpenLink's own navy hero + cyan accent identity."@en ;
    onto:hasTrigger onto:triggerArtifactGeneration ;
    rdfs:seeAlso <infographic-authoring.ttl>, <ui-ux-expert-persona.ttl> .

# ── Step 2: Provenance and Re-Derivation ─────────────────────────────────────

:step-provenanceRederivation a schema:HowToStep ;
    schema:position 2 ;
    schema:name "Treat the recorded palette as a dated snapshot; re-derive from the live site if it may have changed"@en ;
    schema:text "Values were extracted live from openlinksw.com's own computed CSS custom properties on 2026-07-13 (via getComputedStyle over document.styleSheets, not visual guessing), specifically: --opal-primary:#1f4e79, --opal-primary-light:#2d6a9f, --opal-primary-dark:#163a5c, --opal-accent:#00b4ff, --opal-success:#10b981, --opal-gray-50:#f9fafb, --opal-gray-100:#f3f4f6, --opal-gray-200:#e5e7eb, --opal-gray-500:#6b7280, --opal-gray-900:#111827, --ols-blue-dark:#003366, --ols-blue-medium:#336699, --ols-button-hover:#002244, plus --opal-shadow: 0 10px 40px rgba(31,78,121,0.2). Re-derive from the live site rather than copying these literals blind if the brand palette may have changed since 2026-07-13 — treat this file as a snapshot, not an eternal guarantee."@en .

# ── Step 3: Light-vs-Dark Accent Swap ────────────────────────────────────────

:step-accentSwapRationale a schema:HowToStep ;
    schema:position 3 ;
    schema:name "Swap --accent between navy (light mode) and vivid cyan (dark mode) per the bright-accent-for-dark-mode rule"@en ;
    schema:text "In light mode, --accent is the darker/legible navy (#1f4e79, OpenLink's primary brand blue) since it sits on a near-white background; in dark mode, --accent switches to the vivid cyan (#00b4ff, OpenLink's own --opal-accent token) because a dark navy would fail the standing bright-accent-for-dark-mode rule (topicThemeImplementation in preferences.ttl) — it would blend into the dark panel background instead of standing out. --accent2 and --accent3 follow the same light-vs-dark brightening pattern, staying inside the OpenLink palette family (blue-family accent2, green-family accent3 from --opal-success) rather than reintroducing the old generic purple/teal."@en .

# ── Step 4: Verification ─────────────────────────────────────────────────────

:step-paletteVerification a schema:HowToStep ;
    schema:position 4 ;
    schema:name "Confirm applied variables via getComputedStyle in the live preview, not just grep"@en ;
    schema:text "After applying, confirm via getComputedStyle in the live preview (not just grep on the file) that the intended theme's variables actually match the palette — a stale browser cache can silently serve pre-edit CSS and produce a false-positive visual check, as happened once during the 2026-07-13 session (fixed by a cache-busting reload)."@en .

# ── Worked Example: Palette Blocks ───────────────────────────────────────────

:workExample-paletteBlocks a schema:CreativeWork ;
    schema:name "OpenLink brand palette CSS variable blocks"@en ;
    schema:text """LIGHT THEME (:root):
--bg:#f9fafb; --panel:#ffffff; --panel-strong:#ffffff; --ink:#111827; --muted:#6b7280;
--line:#e5e7eb; --accent:#1f4e79; --accent2:#00b4ff; --accent3:#10b981; --chip:#f3f4f6;
--shadow:0 10px 40px rgba(31,78,121,0.2); --radius:16px;

DARK THEME (html[data-theme="dark"] AND @media(prefers-color-scheme:dark) html:not([data-theme="light"]) — both blocks byte-identical):
--bg:#0b1524; --panel:#122238; --panel-strong:#16283f; --ink:#eef2f7; --muted:#93a3ba;
--line:#23344c; --accent:#00b4ff; --accent2:#5fd0ff; --accent3:#34d399; --chip:#1b2d47;
--shadow:0 8px 30px rgba(0,0,0,0.4);"""@en .
