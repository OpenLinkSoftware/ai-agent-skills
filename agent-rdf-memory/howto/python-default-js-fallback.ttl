@prefix schema: <http://schema.org/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix : <#> .

:howto a schema:HowTo ;
    schema:name "Python default; JavaScript only when explicitly required"@en ;
    schema:dateCreated "2026-07-20"^^xsd:date ;
    schema:description "Scripting-language default stated by Kingsley Idehen on 2026-07-20, after build_deploy_sql.js in the fifa-kg-player-reports-vsp bundle was ported to build_deploy_sql.py for consistency with the bundle's other Python tooling (validate_weblog_bundle.py, player_report_create.py)."@en ;
    schema:step :step1, :step2, :step3 .

:step1 a schema:HowToStep ;
    schema:position 1 ;
    schema:text "For new standalone scripts (build/deploy helpers, validators, generators, one-off CLI utilities), write Python by default, not JavaScript/Node."@en .

:step2 a schema:HowToStep ;
    schema:position 2 ;
    schema:text "Use JavaScript/Node only when the user explicitly asks for it, or the task is inherently JS/Node-only (browser-executed code, a Node-specific API/framework, an existing all-JS toolchain being extended in place)."@en .

:step3 a schema:HowToStep ;
    schema:position 3 ;
    schema:text "When an existing .js utility is found with no explicit reason to stay JS, prefer porting it to Python over adding a second Python variant alongside it, to avoid two scripts drifting out of sync."@en .
