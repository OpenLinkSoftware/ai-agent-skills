@prefix : <#> .
@prefix schema: <http://schema.org/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix prov: <http://www.w3.org/ns/prov#> .
@prefix event: <http://purl.org/NET/c4dm/event.owl#> .
@prefix opal: <https://www.openlinksw.com/ontology/opal/> .

<> a schema:CreativeWork ;
    schema:name "Agent Memory Ontology"@en ;
    schema:description "Custom vocabulary for the agent RDF memory system, defining classes for generated artifacts, source articles, memory write triggers, and their relationships."@en ;
    schema:dateModified "2026-07-14T19:30:00Z"^^xsd:dateTime ;
    schema:author <https://linkedin.com/in/kidehen#this> ;
    schema:about :memoryOntology .

:memoryOntology a owl:Ontology ;
    schema:name "Agent Memory Ontology"@en ;
    schema:description "OWL ontology defining vocabulary terms for agent-generated knowledge graph artifacts, source articles, and session memory write triggers."@en ;
    owl:imports <https://www.openlinksw.com/ontology/opal/> ,
        <http://www.w3.org/ns/prov>,
        <http://purl.org/NET/c4dm/event.owl> ;
    rdfs:seeAlso <preferences.ttl>, <core.ttl> .

:GeneratedArtifact a rdfs:Class ;
    rdfs:label "Generated Artifact"@en ;
    rdfs:comment "An RDF, HTML, or MD file generated from a source URL using kg-generator and rdf-infographic-skill."@en ;
    rdfs:isDefinedBy : .

:SourceArticle a rdfs:Class ;
    rdfs:label "Source Article"@en ;
    rdfs:comment "A web article used as the source for knowledge graph generation."@en ;
    rdfs:isDefinedBy : .

:hasSource a owl:ObjectProperty, owl:FunctionalProperty, owl:AsymmetricProperty, owl:IrreflexiveProperty ;
    rdfs:label "has source"@en ;
    rdfs:comment "Links a generated artifact to the single source article it was produced from."@en ;
    rdfs:domain :GeneratedArtifact ;
    rdfs:range :SourceArticle ;
    rdfs:isDefinedBy : .

:hasArtifactPath a owl:DatatypeProperty, owl:FunctionalProperty ;
    rdfs:label "has artifact path"@en ;
    rdfs:comment "Links a generated artifact to its single local filesystem path."@en ;
    rdfs:domain :GeneratedArtifact ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy : .

# ── Memory Write Trigger Vocabulary ──────────────────────────────────────────

# ── Prompt Vocabulary (reuses opal-analytics-ontology-2) ──────────────────

# We reuse opal:ChatSession, opal:ChatMessage, opal:PromptText, and associated
# properties from https://www.openlinksw.com/ontology/opal/ for modeling
# prompt-to-outcome chains. The ontology provides:
#
#   opal:ChatSession   → session container
#   opal:ChatMessage   → individual message (user or assistant)
#   opal:PromptText    → the verbatim text content
#   opal:messageContent → ChatMessage → PromptText
#   opal:messageOf     → ChatMessage → ChatSession
#   opal:hasMessage    → ChatSession → ChatMessage (inverse)
#   opal:messageRole   → "user" | "assistant" | "system"
#   opal:timestamp     → xsd:dateTime of message creation
#   opal:usesTools     → whether tools/skills were invoked
#   opal:chatModel     → session → ChatModel
#   opal:user          → session → foaf:Person
#   opal:provider      → ChatModel → LLMProvider (organization)
#
# Session files should use opal:ChatMessage instances rather than ad-hoc
# prompt entities. The opal vocabulary provides the full interaction model:
# user message → assistant response → tool invocations → artifacts.
#
# Canonical ontology URI for imports:
# <https://www.openlinksw.com/ontology/opal/>
# Local copy for offline resolution:
# <file://{ONTOLOGY_ROOT}/OpenLink/opal-analytics-ontology-2.ttl>

# ── TBox Cross-References to opal-analytics-ontology-2 ─────────────────────

# The opal ontology (https://www.openlinksw.com/ontology/opal/) provides
# opal:ChatSession, opal:ChatMessage, opal:PromptText for modeling LLM
# interactions. Existing session files (pre-2026-06-03) use schema:CreativeWork
# with aggregated schema:description summaries — structurally different from
# the opal message-level model. These TBox axioms enable a reasoner to classify
# local session entities under opal vocabulary and link the two vocabularies,
# without destructive retrofit of existing files.

# Class: local Session ≡ opal ChatSession
:Session a rdfs:Class ;
    rdfs:label "Session"@en ;
    rdfs:comment "A single agent interaction session. Equivalent to opal:ChatSession — the local class exists so reasoners can classify both new opal-modeled sessions and legacy schema:CreativeWork sessions under a common type."@en ;
    rdfs:subClassOf schema:CreativeWork ;
    owl:equivalentClass opal:ChatSession ;
    rdfs:isDefinedBy : .

# Cross-reference: local schema:description → opal aggregate
# A session's schema:description is an aggregated textual summary of the
# conversation. It is NOT structurally equivalent to opal:ChatMessage +
# opal:PromptText (which capture individual messages). We declare it as
# rdfs:seeAlso so tools can navigate from the opal vocabulary to the local
# session model, but a reasoner cannot materialize ChatMessages from it.
#
# For post-2026-06-03 sessions using the full opal model, the description
# serves as a human-readable tl;dr while opal:ChatMessage instances carry
# the verbatim interaction trace.

:Session rdfs:seeAlso opal:ChatSession, opal:ChatMessage, opal:PromptText .

# Property: session authorship maps to opal:user
# schema:author on a :Session (pointing to a foaf:Person or schema:Person)
# is semantically equivalent to opal:user on an opal:ChatSession.
schema:author rdfs:subPropertyOf opal:user ;
    rdfs:isDefinedBy : .

# Property: schema:hasPart on sessions maps to opal:hasMessage (partial)
# schema:hasPart links a session to its generated artifacts; opal:hasMessage
# links a session to its messages. These are not equivalent — one links to
# files, the other to messages — but a reasoner can infer that both describe
# session-contained resources. We use rdfs:seeAlso rather than subPropertyOf
# to avoid incorrect entailments.
schema:hasPart rdfs:seeAlso opal:hasMessage ;
    rdfs:isDefinedBy : .

# Property: prov:wasGeneratedBy on sessions maps to opal:usesTools
# When a session artifact lists prov:wasGeneratedBy pointing to a skill
# (schema:SoftwareApplication), this corresponds to a chat message whose
# opal:usesTools is true. Not structurally equivalent (prov links to
# artifact output, opal links to message), but semantically related.
prov:wasGeneratedBy rdfs:seeAlso opal:usesTools ;
    rdfs:isDefinedBy : .

# What a reasoner CAN infer from these axioms:
#   - Old sessions typed as :Session or schema:CreativeWork can be classified
#     as opal:ChatSession (via owl:equivalentClass on :Session)
#   - schema:author on a session entails opal:user
#   - The opal vocabulary is navigable from local session entities via rdfs:seeAlso
#
# What a reasoner CANNOT infer:
#   - Individual opal:ChatMessage instances from schema:description strings
#   - opal:PromptText entities from aggregated summary text
#   - opal:messageRole, opal:timestamp, or opal:usesTools from legacy sessions
#
# For full message-level traceability, new sessions MUST use the opal model
# directly (opal:ChatSession → opal:hasMessage → opal:ChatMessage →
# opal:messageContent → opal:PromptText) as demonstrated in
# sessions/2026-06-03-deepseek_v4pro-claude_code.ttl.

# ── Memory Write Trigger Vocabulary ──────────────────────────────────────────

:MemoryWriteTrigger a rdfs:Class ;
    rdfs:subClassOf prov:Activity ;
    rdfs:subClassOf event:Event ;
    rdfs:label "Memory Write Trigger"@en ;
    rdfs:comment "A workflow activity that mandates an immediate write to the agent session memory file."@en ;
    schema:name "Memory Write Trigger"@en ;
    schema:description "A narrow subclass of both prov:Activity and event:Event (rdfs:subClassOf, not owl:equivalentClass — event:Event is the generic Event Ontology top class, far broader than this trigger vocabulary) representing a discrete workflow event that triggers a mandatory write to sessions/YYYY-MM-DD-{llm-id}-{agent-env}.ttl."@en ;
    rdfs:isDefinedBy : .

:hasTrigger a owl:ObjectProperty, owl:AsymmetricProperty, owl:IrreflexiveProperty ;
    rdfs:label "has trigger"@en ;
    rdfs:comment "Links a schema:HowToStep to the MemoryWriteTrigger instances that mandate a session memory write. Not owl:FunctionalProperty — a single step commonly fires multiple triggers, as seen throughout preferences.ttl."@en ;
    schema:name "has trigger"@en ;
    rdfs:domain schema:HowToStep ;
    rdfs:range :MemoryWriteTrigger ;
    rdfs:isDefinedBy : .

# ── Trigger Instances ─────────────────────────────────────────────────────────

:triggerPreferencesUpdate a :MemoryWriteTrigger ;
    schema:name "Preferences File Updated"@en ;
    schema:description "Fired when any file in agent-rdf-memory/ (preferences.ttl, core.ttl, ontology.ttl, index.ttl, or any session/project/entity file) is written or modified."@en .

:triggerSkillInvocation a :MemoryWriteTrigger ;
    schema:name "Skill Invocation Completed"@en ;
    schema:description "Fired when any registered skill (kg-generator, data-twingler, rdf-infographic-skill, wikidata-query-skill, document-to-kg-skill, etc.) produces a result."@en .

:triggerNamedWorkflow a :MemoryWriteTrigger ;
    schema:name "Named Workflow Completed"@en ;
    schema:description "Fired on completion of any named-mode workflow: kg-only, kg-hybrid, KG generation, infographic generation, or SPARQL query session."@en .

:triggerBehaviorGapIdentified a :MemoryWriteTrigger ;
    schema:name "Behavior Gap Identified"@en ;
    schema:description "Fired when any correction or gap is identified in the agent's behavior, memory contract, or preferences encoding."@en .

:triggerTopicChange a :MemoryWriteTrigger ;
    schema:name "Topic Change"@en ;
    schema:description "Fired when the user changes topic or signals a natural conversational break between distinct tasks."@en .

:triggerSessionEnd a :MemoryWriteTrigger ;
    schema:name "Session End"@en ;
    schema:description "Fired at the explicit or inferred end of a session. Final write captures all remaining unrecorded events."@en .

:triggerSessionStart a :MemoryWriteTrigger ;
    schema:name "Session Start"@en ;
    schema:description "Fired at the start of every session, after the mandatory memory protocol reads. Triggers semantic prompt analysis and related-session context bootstrapping from the session corpus."@en .

:triggerLogOffloadThreshold a :MemoryWriteTrigger ;
    schema:name "Log Offload Threshold Reached"@en ;
    schema:description "Fired when a single tool result exceeds the size threshold defined in howto/symbolic-log-offloading.ttl, mandating creation of an :OffloadedLog and a :SessionSymbolNode instead of retaining the raw output in context."@en .

# ── Session Memory Loading Path Vocabulary ──────────────────────────────────

:usedFileReads a owl:DatatypeProperty ;
    rdfs:label "used file reads"@en ;
    rdfs:comment "Recorded on a session entity to indicate that memory was loaded via direct filesystem reads. Range is xsd:boolean; value true means file reads were the chosen or actual load path for this session."@en ;
    rdfs:domain schema:Event ;
    rdfs:range xsd:boolean ;
    rdfs:isDefinedBy : .

:usedSparqlEndpoint a owl:ObjectProperty ;
    rdfs:label "used SPARQL endpoint"@en ;
    rdfs:comment "Recorded on a session entity to indicate that memory was loaded via a SPARQL endpoint. The value is the endpoint URL (schema:URL or xsd:anyURI)."@en ;
    rdfs:domain schema:Event ;
    rdfs:isDefinedBy : .

# ── Symbolic Short-Term Log Offloading Vocabulary ────────────────────────────
#
# Every location referenced here is an IRI, never a string literal path —
# file:// for local scratch/session files, https:// for WebDAV-hosted logs,
# and urn:agent-rdf-memory:... for content triplified into a Virtuoso named
# graph. This keeps the vocabulary storage-agnostic: scaling from ad hoc local
# files to a shared quad store is a matter of minting a different kind of IRI,
# not changing the schema. See howto/no-blank-nodes-resolver-entities.ttl for
# the underlying rule that entities must be resolvable resources, not blank
# nodes keyed by opaque literals.
#
# Ontology-discovery gate (per howto/ontology-discovery.ttl) run 2026-07-06:
# PROV-O — already imported by this ontology — defines prov:atLocation
# (owl:ObjectProperty; domain: union of Activity, Agent, Entity,
# InstantaneousEvent; range: prov:Location; non-functional, so a resource may
# carry multiple location values "at varying levels of granularity"). This is
# an exact fit for :OffloadedLog's storage location(s) — including the case
# where a single offloaded log has BOTH a file:// location and an additional
# urn: named-graph location — so it is reused directly instead of minting
# :hasLogIRI and :storedInGraph as bespoke properties. Per user instruction,
# external cross-references (schema.org/DBpedia/Wikidata) are waived for this
# ontology document — Requirement C of howto/ontology-cross-reference-gate.ttl
# is explicitly not applied here.

:OffloadedLog a rdfs:Class ;
    rdfs:subClassOf prov:Entity ;
    rdfs:label "Offloaded Log"@en ;
    rdfs:comment "A raw, verbatim tool-output blob written outside the live session context, addressed by one or more IRIs rather than embedded inline."@en ;
    schema:description "Represents one offloaded tool-call result. Its location(s) are carried via prov:atLocation (reused from PROV-O rather than a custom property) so the same class works whether the content lives as a local file, a WebDAV resource, or a Virtuoso named graph — or more than one of these at once."@en ;
    rdfs:isDefinedBy : .

:SessionSymbolNode a rdfs:Class ;
    rdfs:subClassOf schema:Thing ;
    rdfs:label "Session Symbol Node"@en ;
    rdfs:comment "The compact in-context stand-in for an OffloadedLog. Always minted as its own IRI (urn:agent-rdf-memory:node:{session-id}:{slug}) — never a blank node distinguished by a literal identifier property."@en ;
    schema:description "A lightweight, resolvable reference the agent keeps in its reasoning instead of the raw offloaded content. The {slug} local-name segment (n3, n4, ...) is part of the IRI itself and doubles as the short prose label ('see node n3')."@en ;
    rdfs:isDefinedBy : .

:offloadsTo a owl:ObjectProperty ;
    rdfs:label "offloads to"@en ;
    rdfs:comment "Links a SessionSymbolNode IRI to the OffloadedLog IRI holding its raw content."@en ;
    rdfs:domain :SessionSymbolNode ;
    rdfs:range :OffloadedLog ;
    rdfs:isDefinedBy : .

# ── Prompt Intent and SPARQL Context Routing Vocabulary ──────────────────────
#
# These terms let the session-start harness move from a prompt's inferred
# intent to the exact preference topics, howto documents, recent-session
# context, and endpoint policy needed for that turn. The design is
# endpoint-neutral: {CNAME} is a template variable for the target host or full
# endpoint family, not a synonym for localhost. Implementations may bind it to
# local Virtuoso on :8890 or :443, URIBurner, Demo, or a user-specified endpoint.

:PromptIntent a rdfs:Class ;
    rdfs:subClassOf schema:Intangible ;
    rdfs:label "Prompt Intent"@en ;
    rdfs:comment "A classified task intent derived from the user's prompt and used to route targeted RDF memory context."@en ;
    rdfs:isDefinedBy : .

:RetrievalPolicy a rdfs:Class ;
    rdfs:subClassOf schema:Intangible ;
    rdfs:label "Retrieval Policy"@en ;
    rdfs:comment "A policy describing whether context retrieval should prefer a SPARQL endpoint, local files, URIBurner, or a user-specified endpoint."@en ;
    rdfs:isDefinedBy : .

:ContextSource a rdfs:Class ;
    rdfs:subClassOf schema:Intangible ;
    rdfs:label "Context Source"@en ;
    rdfs:comment "A source category used by the memory harness, such as ontology.ttl, preferences.ttl, index.ttl, howto documents, and session graphs."@en ;
    rdfs:isDefinedBy : .

:EndpointTemplate a rdfs:Class ;
    rdfs:subClassOf schema:Intangible ;
    rdfs:label "Endpoint Template"@en ;
    rdfs:comment "A templated SPARQL endpoint and graph-base description. {CNAME} is substituted with the selected local, remote, or user-specified target."@en ;
    rdfs:isDefinedBy : .

:routesToTopic a owl:ObjectProperty ;
    rdfs:label "routes to topic"@en ;
    rdfs:comment "Links a PromptIntent to the preference topic that contains the governing operational rules."@en ;
    rdfs:domain :PromptIntent ;
    rdfs:range schema:Thing ;
    rdfs:isDefinedBy : .

:requiresHowTo a owl:ObjectProperty ;
    rdfs:label "requires howto"@en ;
    rdfs:comment "Links a PromptIntent to a howto RDF document that must be consulted when that intent applies."@en ;
    rdfs:domain :PromptIntent ;
    rdfs:isDefinedBy : .

:optionalHowTo a owl:ObjectProperty ;
    rdfs:label "optional howto"@en ;
    rdfs:comment "Links a PromptIntent to a howto RDF document that may be consulted when the prompt's details require it."@en ;
    rdfs:domain :PromptIntent ;
    rdfs:isDefinedBy : .

:retrievalPolicy a owl:ObjectProperty ;
    rdfs:label "retrieval policy"@en ;
    rdfs:comment "Links a PromptIntent to its preferred context retrieval policy."@en ;
    rdfs:domain :PromptIntent ;
    rdfs:range :RetrievalPolicy ;
    rdfs:isDefinedBy : .

:requiresRecentSession a owl:DatatypeProperty ;
    rdfs:label "requires recent session"@en ;
    rdfs:comment "Boolean flag indicating that the harness must retrieve recent or intent-relevant session context."@en ;
    rdfs:domain :PromptIntent ;
    rdfs:range xsd:boolean ;
    rdfs:isDefinedBy : .

:preferredContextSource a owl:ObjectProperty ;
    rdfs:label "preferred context source"@en ;
    rdfs:comment "Links a PromptIntent to the context source categories that should be queried first."@en ;
    rdfs:domain :PromptIntent ;
    rdfs:range :ContextSource ;
    rdfs:isDefinedBy : .

:triggerPhrase a owl:DatatypeProperty ;
    rdfs:label "trigger phrase"@en ;
    rdfs:comment "Lexical hint used only for intent classification or fallback retrieval; context selection should follow structured ontology links once intent is known."@en ;
    rdfs:domain :PromptIntent ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy : .

:endpointUrlTemplate a owl:DatatypeProperty ;
    rdfs:label "endpoint URL template"@en ;
    rdfs:comment "Templated SPARQL endpoint URL. https://{CNAME}/sparql is the general endpoint pattern, including localhost when HTTPS is selected; http://localhost:8890/sparql is a local-only Virtuoso endpoint pattern and must not be generalized to non-local CNAME values."@en ;
    rdfs:domain :EndpointTemplate ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy : .

:graphBaseTemplate a owl:DatatypeProperty ;
    rdfs:label "graph base template"@en ;
    rdfs:comment "Templated named-graph IRI base used in generated context-selector queries. Local Virtuoso imports may use urn:dav:/DAV/... graph IRIs even when entity IRIs use http:/DAV/... bases."@en ;
    rdfs:domain :EndpointTemplate ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy : .

:entityBaseTemplate a owl:DatatypeProperty ;
    rdfs:label "entity base template"@en ;
    rdfs:comment "Templated entity IRI base used for prefixes and VALUES subjects inside imported RDF graphs. This may differ from the named graph IRI base."@en ;
    rdfs:domain :EndpointTemplate ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy : .

:sparqlEndpointPreferred a :RetrievalPolicy ;
    schema:name "SPARQL endpoint preferred"@en ;
    schema:description "Use ontology-routed SELECT queries against the configured SPARQL endpoint first; fall back to local file reads if the endpoint is unavailable or incomplete."@en .

:localFilesFallback a :RetrievalPolicy ;
    schema:name "Local files fallback"@en ;
    schema:description "Read agent-rdf-memory files directly when endpoint lookup is unavailable, incomplete, or inappropriate for the task."@en .

:userSpecifiedEndpointPreferred a :RetrievalPolicy ;
    schema:name "User-specified endpoint preferred"@en ;
    schema:description "Use the endpoint URL explicitly provided by the user for the current task."@en .

:OntologyContextSource a :ContextSource ;
    schema:name "ontology.ttl"@en .

:PreferencesContextSource a :ContextSource ;
    schema:name "preferences.ttl"@en .

:IndexContextSource a :ContextSource ;
    schema:name "index.ttl"@en .

:HowToContextSource a :ContextSource ;
    schema:name "howto/*.ttl"@en .

:SessionContextSource a :ContextSource ;
    schema:name "sessions/*.ttl or session named graphs"@en .

:AgentRdfMemoryEndpointTemplate a :EndpointTemplate ;
    schema:name "Agent RDF Memory SPARQL endpoint template"@en ;
    schema:description "Bind {CNAME} to the selected target. Public harness templates remain endpoint-neutral; private overlays may define a user-specific endpoint order. Use https://{CNAME}/sparql as the general HTTPS pattern, including localhost when HTTPS is selected. Use http://localhost:8890/sparql only for the local Virtuoso 8890 endpoint; port 8890 is not a general CNAME template. Do not hardcode localhost in reusable harness queries unless that endpoint has been selected for the current run. For local Virtuoso RDF Import DET loads, discover named graph IRIs with SAMPLE() aggregation and expect graph IRIs such as urn:dav:/DAV/home/kidehen/rdf-import-test/{file}.ttl while entity IRIs use http:/DAV/home/kidehen/rdf-import-test/{file}.ttl#... ."@en ;
    :endpointUrlTemplate "https://{CNAME}/sparql" ;
    :endpointUrlTemplate "http://localhost:8890/sparql" ;
    :graphBaseTemplate "https://{CNAME}/DAV/home/kidehen/ai-related/" ;
    :graphBaseTemplate "urn:dav:/DAV/home/{USER}/rdf-import-test/" ;
    :entityBaseTemplate "http:/DAV/home/{USER}/rdf-import-test/" .

:SparqlTask a rdfs:Class ;
    rdfs:subClassOf :PromptIntent ;
    rdfs:label "SPARQL Task"@en ;
    rdfs:comment "Prompt intent involving SPARQL query construction, diagnosis, endpoint usage, or result interpretation."@en ;
    rdfs:isDefinedBy : .

:VirtuosoSparqlTroubleshooting a owl:Class ;
    rdfs:subClassOf :SparqlTask ;
    rdfs:label "Virtuoso SPARQL Troubleshooting"@en ;
    rdfs:comment "Prompt intent for diagnosing Virtuoso SPARQL endpoint, compiler, full-text search, named graph, format, or describe-page issues."@en ;
    :routesToTopic <preferences.ttl#topic-virtuoso-sparql> ;
    :requiresHowTo <howto/virtuoso-sparql-formats.ttl>, <howto/virtuoso-workbench-query-dedup.ttl> ;
    :optionalHowTo <howto/sparql-absolute-prefix-iri.ttl>, <howto/sparql-memory-loading.ttl> ;
    :retrievalPolicy :sparqlEndpointPreferred ;
    :requiresRecentSession true ;
    :preferredContextSource :OntologyContextSource, :PreferencesContextSource, :IndexContextSource, :HowToContextSource, :SessionContextSource ;
    :triggerPhrase "SPARQL compiler", "Virtuoso 37000", "SP031", "bif:contains", "describe page", "default-graph-uri", "format=text/x-html+tr" ;
    rdfs:isDefinedBy : .

:RdfAuthoringTask a owl:Class ;
    rdfs:subClassOf :PromptIntent ;
    rdfs:label "RDF Authoring Task"@en ;
    :routesToTopic <preferences.ttl#topic-rdf-authoring> ;
    :retrievalPolicy :sparqlEndpointPreferred ;
    :requiresRecentSession true ;
    :preferredContextSource :OntologyContextSource, :PreferencesContextSource, :HowToContextSource, :SessionContextSource ;
    :triggerPhrase "RDF", "Turtle", "JSON-LD", "IRI", "blank node", "schema:about" ;
    rdfs:isDefinedBy : .

:IdentityWebIdTask a owl:Class ;
    rdfs:subClassOf :PromptIntent ;
    rdfs:label "Identity and WebID Task"@en ;
    :routesToTopic <preferences.ttl#topic-identity-webid> ;
    :retrievalPolicy :sparqlEndpointPreferred ;
    :requiresRecentSession true ;
    :preferredContextSource :OntologyContextSource, :PreferencesContextSource, :HowToContextSource, :SessionContextSource ;
    :triggerPhrase "whoami", "who am I", "WebID", "delegation", "On-Behalf-Of", "NetID" ;
    rdfs:isDefinedBy : .

:ArtifactRoutingTask a owl:Class ;
    rdfs:subClassOf :PromptIntent ;
    rdfs:label "Artifact Routing Task"@en ;
    :routesToTopic <preferences.ttl#topic-artifact-routing> ;
    :retrievalPolicy :sparqlEndpointPreferred ;
    :requiresRecentSession true ;
    :preferredContextSource :OntologyContextSource, :PreferencesContextSource, :HowToContextSource, :SessionContextSource ;
    :triggerPhrase "output path", "save", "artifact", "DAV", "publish", "route" ;
    rdfs:isDefinedBy : .

:KgExplorerTask a owl:Class ;
    rdfs:subClassOf :PromptIntent ;
    rdfs:label "KG Explorer Task"@en ;
    :routesToTopic <preferences.ttl#topic-html-kg-explorer> ;
    :retrievalPolicy :sparqlEndpointPreferred ;
    :requiresRecentSession true ;
    :preferredContextSource :OntologyContextSource, :PreferencesContextSource, :HowToContextSource, :SessionContextSource ;
    :triggerPhrase "KG Explorer", "D3", "graph visualization", "SPARQL workbench", "harness" ;
    rdfs:isDefinedBy : .

:MemoryProtocolTask a owl:Class ;
    rdfs:subClassOf :PromptIntent ;
    rdfs:label "Memory Protocol Task"@en ;
    :routesToTopic <preferences.ttl#topic-memory-management> ;
    :retrievalPolicy :sparqlEndpointPreferred ;
    :requiresRecentSession true ;
    :preferredContextSource :OntologyContextSource, :PreferencesContextSource, :IndexContextSource, :HowToContextSource, :SessionContextSource ;
    :triggerPhrase "memory protocol", "agent-rdf-memory", "preferences.ttl", "index.ttl", "ontology.ttl", "sessions" ;
    rdfs:isDefinedBy : .

:SkillWorkflowTask a owl:Class ;
    rdfs:subClassOf :PromptIntent ;
    rdfs:label "Skill Workflow Task"@en ;
    :routesToTopic <preferences.ttl#topic-skill-workflows> ;
    :retrievalPolicy :sparqlEndpointPreferred ;
    :requiresRecentSession true ;
    :preferredContextSource :OntologyContextSource, :PreferencesContextSource, :HowToContextSource, :SessionContextSource ;
    :triggerPhrase "skill", "workflow", "kg-only", "URIBurner", "data-twingler", "SPARQL endpoint" ;
    rdfs:isDefinedBy : .
