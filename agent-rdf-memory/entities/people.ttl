@prefix : <#> .
@prefix schema: <http://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dbr: <http://dbpedia.org/resource/> .

<> a schema:CreativeWork ;
    schema:name "Entity Registry: People"@en ;
    schema:description "Canonical schema:Person entity IRIs for individuals recurring across the agent RDF memory system. This is the authoritative single-source-of-truth — agents MUST consult this registry before resolving a person entity, and MUST register newly resolved person IRIs here rather than only in session files. Populated 2026-07-14 from a SPARQL census of schema:Person instances across all DAV named graphs (1,271 instances, 1,150 distinct IRIs, 499 owl:sameAs/name-merged clusters, 41 recurring in >= 3 documents)."@en ;
    schema:dateCreated "2026-07-08T00:00:00Z"^^xsd:dateTime ;
    schema:dateModified "2026-07-14T00:00:00Z"^^xsd:dateTime ;
    schema:author <https://linkedin.com/in/kidehen#this> ;
    schema:about :kingsleyIdehen, :tonySeale, :satyaNadella, :jayaGupta, :alexKarp,
        :aaronLevie, :jessicaTalisman, :robertScoble, :adedejiOlowe, :veronikaHeimsbakk,
        :abhiYadav, :irenaCronin, :scottBrinker, :richardMacManus, :ngoziDozie,
        :prukalpaSankar, :fransRiemersma, :robertSanderson, :timBernersLee, :jkRowling,
        :reidHoffman, :omMalik, :juanSequeda, :aakashGupta, :guyDebord, :mohamedSalah,
        :joostDeValk, :gauravMalhotra, :samAltman, :stuartMichaelEdelenbos, :saanyaOjha,
        :danielAtherton, :popeLeoXIV, :florianWirtz, :jonathanJaffe, :virgilVanDijk,
        :nickZervoudis, :vivianVoss, :dennisJuarez, :naomiXia, :tomaszTunguz,
        :andrejKarpathy, :henryYin ;
    rdfs:seeAlso <../preferences.ttl>, <../core.ttl>,
        <../howto/canonical-entity-iri-denotation.ttl>,
        <../howto/entity-iri-denotation-mechanics.ttl>,
        <../howto/external-iri-verification.ttl>,
        <../howto/cross-document-local-term-reuse.ttl> .

# ═══════════════════════════════════════════════════════════════════════════════
# ── Correction note (2026-07-14) ────────────────────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
#
# Three entries added earlier the same session (Jaya Gupta, Alex Karp, Aaron
# Levie) carried unverified/incorrect canonical IRIs, caught by cross-checking
# against corpus documents already read this session:
#   - :jayaGupta was <...linkedin.com/in/jayagupta#this> — WRONG. Verified form
#     (ai-value-capture-response-claude_sonnet_5-1.ttl) is jayagupta10.
#   - :aaronLevie was <...linkedin.com/in/aaron-levie#this> — WRONG. Verified
#     form (aaron-levie-enterprise-ai-agent-issues-...ttl) is boxaaron.
#   - :alexKarp was <...linkedin.com/in/alexkarp#this> — UNVERIFIED/fabricated.
#     No document in this corpus ever asserts a personal LinkedIn IRI for Karp;
#     only dbr:Alex_Karp (DBpedia) appears. Corrected to DBpedia canonical per
#     the no-fabricated-URLs rule.
# Lesson: a registry entry must be checked against already-read source
# documents, not asserted from model recall of a plausible-looking slug.

:kingsleyIdehen a schema:Person ;
    schema:name "Kingsley Uyi Idehen"@en ;
    schema:email "kidehen@openlinksw.com" ;
    schema:jobTitle "Founder & CEO"@en ;
    schema:worksFor <http://dbpedia.org/resource/OpenLink_Software> ;
    owl:sameAs <https://linkedin.com/in/kidehen#this>,
               <https://www.linkedin.com/in/kidehen#this>,
               <https://x.com/kidehen#this>,
               <https://substack.com/@kidehen#this> ;
    rdfs:comment "Canonical entity IRI. First resolved in agent-rdf-memory/core.ttl (:user entity). Linkedin.com (non-www) is the canonical form. Census 2026-07-14: 37 documents, 59 distinct IRI variants (github, mastodon, bsky, threads, tiktok, medium, etc.) — only the primary platform forms are listed here; the census confirms recurrence, not that every platform alias needs enumeration."@en ;
    schema:dateCreated "2026-05-27T00:00:00Z"^^xsd:dateTime .

