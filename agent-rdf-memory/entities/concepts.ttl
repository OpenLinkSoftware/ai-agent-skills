@prefix : <#> .
@prefix schema: <http://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .
@prefix dbr: <http://dbpedia.org/resource/> .
@prefix irefde: <https://x.com/kidehen/status/2055725483535282591##> .

<> a schema:CreativeWork ;
    schema:name "Entity Registry: Concepts & Defined Terms"@en ;
    schema:description "Canonical schema:DefinedTerm entity IRIs for recurring conceptual entities across the agent RDF memory system. Concepts are abstract notions (Semantic Web, Linked Data, WebID, DPKI) that recur across KG generations and session analyses. This is the authoritative single-source-of-truth — agents MUST consult this registry before resolving a concept entity, using the highest-priority canonical IRI available."@en ;
    schema:dateCreated "2026-07-08T00:00:00Z"^^xsd:dateTime ;
    schema:dateModified "2026-07-14T00:00:00Z"^^xsd:dateTime ;
    schema:author <https://linkedin.com/in/kidehen#this> ;
    schema:about :semanticWeb, :linkedData, :knowledgeGraph, :sparqlConcept, :rdfConcept,
        :webid, :dpki, :selfSovereignIdentity, :meshup,
        :forwardDeployedEngineer, :inwardRedeployedEngineer, :aiLiteracySkill, :skillLifecycleState,
        :rdfView, :federatedGraphQuery, :rdfQuadStore,
        :ontology, :owlConcept, :skosConcept, :webdav, :provO, :abac, :digitalTwin,
        :promptInjection, :vibeCoding, :systemOfRecord, :modelContextProtocol, :semanticLayer,
        :contextEngineering, :agenticWeb, :aiAgent, :agentIdentity, :contextGraph,
        :decisionTrace, :containment, :aiGovernance ;
    rdfs:seeAlso <../preferences.ttl>,
        <../howto/canonical-entity-iri-denotation.ttl>,
        <../howto/owl-sameas-vs-skos-related.ttl>,
        <../howto/cross-document-local-term-reuse.ttl> .

# ═══════════════════════════════════════════════════════════════════════════════
# ── DBpedia-Backed Concepts ────────────────────────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
#
# These concepts have verified DBpedia resource IRIs (HTTP 200 dereference,
# verified 2026-07-08). The DBpedia IRI is the canonical form.

# ── Semantic Web ───────────────────────────────────────────────────────────────

:semanticWeb a schema:DefinedTerm ;
    schema:name "Semantic Web"@en ;
    schema:description "A web of linked data — an extension of the World Wide Web in which information is given well-defined meaning via RDF, enabling machines and humans to cooperate. Distinct from 'the Semantic Web' (global vision); 'a Semantic Web' refers to a specific deployment instance."@en ;
    owl:sameAs <http://dbpedia.org/resource/Semantic_Web> ;
    skos:related :linkedData, :rdfConcept, :sparqlConcept ;
    rdfs:comment "Canonical entity IRI. DBpedia resource verified via HTTP 200 dereference (2026-07-08). Recurring concept across session analyses and KG generations. Terminology: use 'a Semantic Web' (indefinite) for instance-specific deployments per step-terminologySemanticWeb."@en ;
    schema:dateCreated "2026-05-29T00:00:00Z"^^xsd:dateTime .

# ── Linked Data ────────────────────────────────────────────────────────────────

:linkedData a schema:DefinedTerm ;
    schema:name "Linked Data"@en ;
    schema:description "A method of publishing structured data using HTTP IRIs, RDF, and SPARQL so that it can be interlinked and become more useful through semantic queries. The fourth principle in Tim Berners-Lee's 5-star open data deployment scheme."@en ;
    owl:sameAs <http://dbpedia.org/resource/Linked_data> ;
    skos:related :semanticWeb, :rdfConcept, :sparqlConcept ;
    rdfs:comment "Canonical entity IRI. DBpedia resource verified via HTTP 200 dereference (2026-07-08). Recurring concept — comparison dimension in multiple KG analyses (Enterprise AI Agents, Systems of Record, YouID/SSI)."@en ;
    schema:dateCreated "2026-05-29T00:00:00Z"^^xsd:dateTime .

# ── Knowledge Graph ────────────────────────────────────────────────────────────

:knowledgeGraph a schema:DefinedTerm ;
    schema:name "Knowledge Graph"@en ;
    schema:description "A structured representation of information as entities and their relationships, typically encoded in RDF and queryable via SPARQL. Knowledge graphs enable semantic integration across heterogeneous data sources."@en ;
    owl:sameAs <http://dbpedia.org/resource/Knowledge_graph>,
        <https://metadataweekly.substack.com/p/ontologies-context-graphs-and-semantic#knowledgeGraph>,
        <https://moderndata101.substack.com/p/the-semantic-medallion#termKnowledgeGraph> ;
    skos:related :semanticWeb, :linkedData, :rdfConcept ;
    rdfs:comment "Canonical entity IRI. DBpedia resource verified via HTTP 200 dereference (2026-07-08). One of the most recurring concepts across all session analyses and KG generations."@en ;
    schema:dateCreated "2026-05-29T00:00:00Z"^^xsd:dateTime .

# ── SPARQL ─────────────────────────────────────────────────────────────────────

:sparqlConcept a schema:DefinedTerm ;
    schema:name "SPARQL"@en ;
    schema:description "SPARQL Protocol and RDF Query Language — the W3C standard query language for RDF data. Enables federated queries across distributed SPARQL endpoints via SERVICE clauses."@en ;
    owl:sameAs <http://dbpedia.org/resource/SPARQL>,
        <https://moderndata101.substack.com/p/the-semantic-medallion#sparqlQueryLanguage>,
        <https://moderndata101.substack.com/p/the-semantic-medallion#termSPARQL>,
        <https://medium.com/virtuoso-blog/dynamically-generating-documents-from-sparql-queries-7d6589505100#sparqlQueryLanguage> ;
    skos:altLabel "SPARQL Query Language"@en ;
    skos:related :rdfConcept, :semanticWeb, :linkedData ;
    rdfs:comment "Canonical entity IRI. DBpedia resource verified via HTTP 200 dereference (2026-07-08). Recurring concept — SPARQL workbench and accordion queries are a standard component of HTML infographics per harness contract."@en ;
    schema:dateCreated "2026-05-29T00:00:00Z"^^xsd:dateTime .

# ── RDF ────────────────────────────────────────────────────────────────────────

:rdfConcept a schema:DefinedTerm ;
    schema:name "RDF"@en ;
    schema:description "Resource Description Framework — the W3C standard for representing information about resources in the Web. Uses subject-predicate-object triples and HTTP IRIs to create a distributed, self-describing data graph."@en ;
    owl:sameAs <http://dbpedia.org/resource/Resource_Description_Framework>,
        <https://moderndata101.substack.com/p/the-semantic-medallion#termRDF>,
        <https://moderndata101.substack.com/p/the-semantic-medallion#rdfStandard>,
        <https://x.com/kidehen/status/2055725483535282591#rdfTerm> ;
    skos:altLabel "RDF — Resource Description Framework"@en ;
    skos:related :sparqlConcept, :semanticWeb, :linkedData ;
    rdfs:comment "Canonical entity IRI. DBpedia resource verified via HTTP 200 dereference (2026-07-08). Foundational concept — RDF is the data model underlying all KG generation and entity resolution in this system."@en ;
    schema:dateCreated "2026-05-29T00:00:00Z"^^xsd:dateTime .

# ═══════════════════════════════════════════════════════════════════════════════
# ── Document-Local Concepts (no verified DBpedia/Wikidata IRI) ────────────────
# ═══════════════════════════════════════════════════════════════════════════════
#
# These concepts lack verified external canonical IRIs. The document-local IRI
# (hash fragment) serves as the canonical form until an external IRI is verified.

# ── WebID ──────────────────────────────────────────────────────────────────────

:webid a schema:DefinedTerm ;
    schema:name "WebID"@en ;
    schema:description "A W3C standard for decentralized digital identity using HTTP IRIs. A WebID profile document (Turtle, JSON-LD, RDFa) links a person or agent to their public keys, enabling WebID-TLS authentication without passwords."@en ;
    owl:sameAs <https://medium.com/virtuoso-blog/dynamically-generating-documents-from-sparql-queries-7d6589505100#gtWebID>,
        <https://medium.com/virtuoso-blog/dynamically-generating-documents-from-sparql-queries-7d6589505100#webid> ;
    skos:related :dpki, :selfSovereignIdentity ;
    rdfs:comment "Document-local entity IRI. No verified DBpedia/Wikidata entry exists for 'WebID' as a distinct concept (DBpedia has 'WebID' as a disambiguation page, not a concept page). Recurring concept across sessions — core topic of YouID identity cards, WebID-TLS verification, and identity delegation."@en ;
    schema:dateCreated "2026-06-14T00:00:00Z"^^xsd:dateTime .

# ── DPKI (Decentralized Public Key Infrastructure) ─────────────────────────────

:dpki a schema:DefinedTerm ;
    schema:name "DPKI"@en ;
    schema:description "Decentralized Public Key Infrastructure — an approach to public key management that eliminates centralized certificate authorities by using decentralized identifiers (DIDs), distributed ledgers, or WebID-based key discovery."@en ;
    skos:related :webid, :selfSovereignIdentity ;
    rdfs:comment "Document-local entity IRI. No verified external IRI exists. Recurring concept in YouID/WebID identity analyses and the Browser PKI Gap narrative."@en ;
    schema:dateCreated "2026-06-19T00:00:00Z"^^xsd:dateTime .

# ── Self-Sovereign Identity ────────────────────────────────────────────────────

:selfSovereignIdentity a schema:DefinedTerm ;
    schema:name "Self-Sovereign Identity"@en ;
    schema:description "A model of digital identity where individuals and organizations have sole ownership and control over their identity data, credentials, and authentication mechanisms — without relying on centralized identity providers."@en ;
    skos:related :webid, :dpki ;
    rdfs:comment "Document-local entity IRI. No verified external IRI exists (DBpedia/Wikidata cover 'Self-sovereign identity' but the exact IRI and label need verification before owl:sameAs). Recurring concept — central theme of YouID identity comparisons (AIAM vs YouID vs Sovereign Subject)."@en ;
    schema:dateCreated "2026-06-19T00:00:00Z"^^xsd:dateTime .

# ── meshup ─────────────────────────────────────────────────────────────────────

:meshup a schema:DefinedTerm ;
    schema:name "meshup"@en ;
    schema:description "Semantic content fusion — the process of combining and enriching information from multiple sources using Linked Data and RDF to produce a semantically coherent, queryable knowledge graph. The preferred term per step-mashupVsMeshup (position 4 in preferences.ttl)."@en ;
    skos:related :semanticWeb, :linkedData ;
    rdfs:comment "Document-local entity IRI. Terminological preference recorded in preferences.ttl step-mashupVsMeshup (position 4): never use 'mashup' — always use 'meshup' for semantic content fusion."@en ;
    schema:dateCreated "2026-05-29T00:00:00Z"^^xsd:dateTime .

# ═══════════════════════════════════════════════════════════════════════════════
# ── Ontology-Term-Backed Concepts (backed by this agent's own published ontologies) ──
# ═══════════════════════════════════════════════════════════════════════════════
#
# Promoted 2026-07-14 per step-crossDocumentLocalTermReuse (position 127 in
# preferences.ttl): these terms recurred across two or more independently
# generated documents and are backed by a stable, resolver-dereferenceable
# rdfs:Class published in a prior doc-collection production run. owl:sameAs
# points to that origin class rather than restating its definition.

:forwardDeployedEngineer a schema:DefinedTerm ;
    schema:name "Forward Deployed Engineer (FDE)"@en ;
    schema:description "An outward-facing engineering role embedded in customer environments to deploy and adapt AI systems in real-world contexts; the execution and integration interface between an AI vendor's systems and a customer's operations."@en ;
    owl:sameAs irefde:ForwardDeployedEngineer,
        <https://www.forbes.com/sites/stevebanker/2026/05/16/palantir-says-saas-is-dead/#termFDE>,
        <https://www.forbes.com/sites/stevebanker/2026/05/16/palantir-says-saas-is-dead#forwardDeployedTerm> ;
    skos:altLabel "Forward-Deployed Engineer"@en ;
    skos:related :inwardRedeployedEngineer, :aiLiteracySkill ;
    rdfs:comment "Origin class: irefde:ForwardDeployedEngineer in the FDE/IRE Enterprise Skills, Lifecycle & Provenance Ontology (ire-fde-ontology-roles). Reused, not restated, in the Aaron Levie enterprise-AI-agent-issues KG (2026-07-08)."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:inwardRedeployedEngineer a schema:DefinedTerm ;
    schema:name "Inward Redeployed Engineer (IRE)"@en ;
    schema:description "An inward-facing engineering role that extracts tacit organizational knowledge and codifies it into structured, reusable, AI-executable skill artifacts — the internal knowledge-compression layer converting FDE deployment experience into reusable Skills."@en ;
    owl:sameAs irefde:InwardRedeployedEngineer ;
    skos:related :forwardDeployedEngineer, :aiLiteracySkill ;
    rdfs:comment "Origin class: irefde:InwardRedeployedEngineer in the FDE/IRE Enterprise Skills, Lifecycle & Provenance Ontology (ire-fde-ontology-roles). Reused, not restated, in the Aaron Levie enterprise-AI-agent-issues KG (2026-07-08)."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:aiLiteracySkill a schema:DefinedTerm ;
    schema:name "AI Literacy Skill"@en ;
    schema:description "One of nine core capabilities (LLM mastery, agent engineering, skill engineering, data space tooling, API interoperability, HTTP protocol mastery, linked data and semantic web, data access protocols, declarative query languages) required to move an enterprise from AI consumption to AI-native operational design."@en ;
    owl:sameAs irefde:AILiteracySkill,
        <https://x.com/kidehen/status/2055725483535282591#AILiteracy> ;
    skos:altLabel "AI Literacy Skills"@en ;
    skos:related :forwardDeployedEngineer, :inwardRedeployedEngineer, :skillLifecycleState ;
    rdfs:comment "Origin class: irefde:AILiteracySkill in the FDE/IRE Enterprise Skills, Lifecycle & Provenance Ontology (ire-fde-ontology-roles)."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:skillLifecycleState a schema:DefinedTerm ;
    schema:name "Skill Lifecycle State"@en ;
    schema:description "Governance state tracking a Skill artifact through its operational lifecycle — Proposed, Validated, Deployed, or Deprecated — from formation to retirement."@en ;
    owl:sameAs irefde:SkillLifecycleState ;
    skos:related :aiLiteracySkill ;
    rdfs:comment "Origin class: irefde:SkillLifecycleState in the FDE/IRE Enterprise Skills, Lifecycle & Provenance Ontology (ire-fde-ontology-roles)."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

# ── Virtuoso / Linked Data technical vocabulary (document-local, no verified external IRI) ──

:rdfView a schema:DefinedTerm ;
    schema:name "RDF View (R2RML)"@en ;
    schema:description "A W3C-standard mapping that exposes an existing relational database as an RDF graph without copying or migrating the underlying data."@en ;
    skos:related :rdfConcept, :linkedData ;
    rdfs:seeAlso <https://www.w3.org/TR/r2rml/> ;
    rdfs:comment "Document-local entity IRI, first minted as :termRdfView in the Aaron Levie enterprise-AI-agent-issues KG (2026-07-08). rdfs:seeAlso points to the R2RML W3C Recommendation rather than owl:sameAs, since the spec document is not itself the individual concept."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:federatedGraphQuery a schema:DefinedTerm ;
    schema:name "Federated Graph Query"@en ;
    schema:description "A graph query language feature letting one query span multiple independent SPARQL endpoints — the query-time equivalent of crossing organizational data silos."@en ;
    skos:related :sparqlConcept, :rdfQuadStore ;
    rdfs:comment "Document-local entity IRI, first minted as :termFederatedQuery in the Aaron Levie enterprise-AI-agent-issues KG (2026-07-08). No verified external DBpedia/Wikidata IRI exists for this specific technical concept."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:rdfQuadStore a schema:DefinedTerm ;
    schema:name "RDF Quad Store"@en ;
    schema:description "A triple store extended with a fourth, named-graph element per statement, used to attach provenance, source, or department context to every fact."@en ;
    skos:related :rdfConcept, :federatedGraphQuery ;
    rdfs:comment "Document-local entity IRI, first minted as :termQuadStore in the Aaron Levie enterprise-AI-agent-issues KG (2026-07-08). No verified external DBpedia/Wikidata IRI exists for this specific technical concept."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

# ═══════════════════════════════════════════════════════════════════════════════
# ── Corpus-Distilled Concepts (URIBurner DAV named-graph DefinedTerm census) ──
# ═══════════════════════════════════════════════════════════════════════════════
#
# Promoted 2026-07-14 per step-crossDocumentLocalTermReuse (position 127 in
# preferences.ttl). Method: SPARQL census of all schema:DefinedTerm instances
# across named graphs matching https://linkeddata.uriburner.com/DAV/demos/daas/*
# (149 graphs, 2,141 instances, 1,163 distinct concepts after normalization).
# Every concept below recurred across >= 3 independently generated documents —
# i.e. it was re-minted repeatedly under disjoint document-local IRIs. These
# entries end that: future doc-collection tasks MUST reuse the canonical IRIs
# below instead of minting yet another local equivalent. owl:sameAs links each
# entry to its verified DBpedia IRI (where one exists) and to the most-recurrent
# previously-published document IRI, preserving cross-corpus graph merge.
# All DBpedia IRIs verified via https://dbpedia.org/data/{resource}.json
# (HTTP 200, own rdfs:label + description, 2026-07-14).

# ── DBpedia-backed (verified external canonical IRI) ──────────────────────────

:ontology a schema:DefinedTerm ;
    schema:name "Ontology"@en ;
    schema:description "A formal model of classes, properties, and relationships shared by a community of interest — the schema layer that makes knowledge graphs machine-computable and reasonable-over."@en ;
    owl:sameAs <http://dbpedia.org/resource/Ontology_(information_science)>,
        <https://x.com/kidehen/status/2055725483535282591#ontologyTerm> ;
    skos:related :knowledgeGraph, :owlConcept, :skosConcept ;
    rdfs:comment "Recurred in 10 corpus documents under disjoint local IRIs. Canonical: DBpedia (verified 2026-07-14); most-recurrent published local IRI linked via owl:sameAs."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:owlConcept a schema:DefinedTerm ;
    schema:name "OWL (Web Ontology Language)"@en ;
    schema:description "The W3C Web Ontology Language, used for formal class/property definitions and reasoning structures atop RDF."@en ;
    owl:sameAs <http://dbpedia.org/resource/Web_Ontology_Language>,
        <https://www.linkedin.com/pulse/context-gap-jessica-talisman-pexvc#concept-owl> ;
    skos:related :ontology, :rdfConcept ;
    rdfs:comment "Recurred in 5 corpus documents. Canonical: DBpedia (verified 2026-07-14)."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:skosConcept a schema:DefinedTerm ;
    schema:name "SKOS (Simple Knowledge Organization System)"@en ;
    schema:description "W3C model for controlled vocabularies, concept schemes, taxonomies, and thesauri."@en ;
    owl:sameAs <http://dbpedia.org/resource/Simple_Knowledge_Organization_System>,
        <https://www.linkedin.com/pulse/context-gap-jessica-talisman-pexvc#concept-skos> ;
    skos:related :ontology, :owlConcept ;
    rdfs:comment "Recurred in 3 corpus documents. Canonical: DBpedia (verified 2026-07-14)."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:webdav a schema:DefinedTerm ;
    schema:name "WebDAV"@en ;
    schema:description "HTTP extension for distributed authoring — used across this corpus as the mounted-folder workflow for publishing generated RDF and HTML artifacts to resolvable URLs."@en ;
    owl:sameAs <http://dbpedia.org/resource/WebDAV>,
        <https://www.linkedin.com/pulse/context-gap-jessica-talisman-pexvc#concept-webdav> ;
    skos:related :linkedData ;
    rdfs:comment "Recurred in 3 corpus documents. Canonical: DBpedia (verified 2026-07-14)."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:provO a schema:DefinedTerm ;
    schema:name "PROV-O (Provenance Ontology)"@en ;
    schema:description "The W3C provenance ontology recording which activity generated a piece of data, by whom, and from what — used across this corpus to link agent activity to attributable outcomes."@en ;
    owl:sameAs <http://dbpedia.org/resource/PROV_(Provenance)>,
        <https://moderndata101.substack.com/p/the-semantic-medallion#termPROVO>,
        <https://moderndata101.substack.com/p/the-semantic-medallion#provOntology> ;
    skos:altLabel "PROV-O — Provenance Ontology"@en ;
    skos:broader :ontology ;
    skos:related :rdfConcept ;
    rdfs:seeAlso <https://www.w3.org/TR/prov-o/> ;
    rdfs:comment "Recurred in 3 corpus documents, plus provenance-oriented-ontology variants elsewhere. Canonical: DBpedia (verified 2026-07-14); W3C Recommendation via rdfs:seeAlso."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:abac a schema:DefinedTerm ;
    schema:name "Attribute-Based Access Control (ABAC)"@en ;
    schema:description "Fine-grained access control that grants or denies dereference/use of a resource based on attributes of the requester, resource, action, and context, rather than fixed roles alone."@en ;
    owl:sameAs <http://dbpedia.org/resource/Attribute-based_access_control>,
        <https://linkeddata.uriburner.com/DAV/demos/daas/ai-value-capture-response-claude_sonnet_5-1.ttl#abac>,
        <https://www.linkedin.com/pulse/software-losing-its-head-seema-amble-6qmnc#term-accessControl> ;
    skos:broader <https://medium.com/virtuoso-blog/dynamically-generating-documents-from-sparql-queries-7d6589505100#accessControl> ;
    skos:related :webid, :agentIdentity ;
    rdfs:comment "Recurred in 3+ corpus documents including the avc: trilogy (ai-value-capture-response, reverse-information-paradox). Canonical: DBpedia (verified 2026-07-14); avc:abac was the first agent-minted IRI and is preserved via owl:sameAs."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:digitalTwin a schema:DefinedTerm ;
    schema:name "Digital Twin"@en ;
    schema:description "A virtual replica of a person, object, or process — in this corpus most often an AI-generated copy of a person trained on their archives, capable of interactive pseudo-conversation."@en ;
    owl:sameAs <http://dbpedia.org/resource/Digital_twin>,
        <https://om.co/2026/05/26/the-copy-and-the-guru#termDigitalTwin> ;
    rdfs:comment "Recurred in 5 corpus documents. Canonical: DBpedia (verified 2026-07-14)."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:promptInjection a schema:DefinedTerm ;
    schema:name "Prompt Injection"@en ;
    schema:description "Malicious instructions embedded in content that an AI agent reads, causing it to act against its principal's intent."@en ;
    owl:sameAs <http://dbpedia.org/resource/Prompt_injection>,
        <https://www.anthropic.com/engineering/how-we-contain-claude#term-prompt-injection> ;
    skos:related :containment, :agentIdentity ;
    rdfs:comment "Recurred in 3 corpus documents. Canonical: DBpedia (verified 2026-07-14)."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:vibeCoding a schema:DefinedTerm ;
    schema:name "Vibe Coding"@en ;
    schema:description "Building software via AI without traditional engineering rigor — natural-language-driven development where AI-generated code creates real economic value."@en ;
    owl:sameAs <http://dbpedia.org/resource/Vibe_coding>,
        <https://dejiolowe.com/2026/03/30/ai-will-only-help-those-with-agency/#vibeCodingTerm> ;
    skos:related :aiAgent ;
    rdfs:comment "Recurred in 3 corpus documents. Canonical: DBpedia (verified 2026-07-14)."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:systemOfRecord a schema:DefinedTerm ;
    schema:name "System of Record"@en ;
    schema:description "The authoritative source of truth for business data, process state, and institutional context."@en ;
    owl:sameAs <http://dbpedia.org/resource/System_of_record>,
        <https://www.linkedin.com/pulse/software-losing-its-head-seema-amble-6qmnc#systemOfRecord>,
        <https://www.linkedin.com/posts/darlenenewman_there-are-three-kinds-of-ai-enablement-programs-share-7465379435911847937-HBbM/#systems-of-record> ;
    skos:altLabel "Systems of Record"@en ;
    skos:related :knowledgeGraph, :semanticLayer ;
    rdfs:comment "Recurred in 3 corpus documents. Canonical: DBpedia (verified 2026-07-14)."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:modelContextProtocol a schema:DefinedTerm ;
    schema:name "Model Context Protocol (MCP)"@en ;
    schema:description "An open protocol for exposing tools, resources, and prompts to AI agent clients — JSON-RPC over transports such as Streamable HTTP — now the de facto standard for AI-to-tool communication."@en ;
    owl:sameAs <http://dbpedia.org/resource/Model_Context_Protocol>,
        <https://joost.blog/agent-ready/#mcpProtocol> ;
    skos:related :aiAgent, :agenticWeb ;
    rdfs:comment "Recurred in 6 corpus documents. Canonical: DBpedia (verified 2026-07-14)."@en ;
