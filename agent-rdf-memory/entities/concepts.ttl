    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:agenticWeb a schema:DefinedTerm ;
    schema:name "Agentic Web"@en ;
    schema:description "A Web pattern in which user-directed agents act across sites and data spaces — part of the human web, not separate from it — reducing platform lock-in via shared open standards."@en ;
    owl:sameAs <https://vivianvoss.net/blog/linkedin-reach-you-did-not-earn#term-agentic-web> ;
    skos:related :aiAgent, :modelContextProtocol, :linkedData ;
    rdfs:comment "Recurred in 6 corpus documents. No verified DBpedia/Wikidata IRI as of 2026-07-14 (dbpedia:Agentic_AI is adjacent but not identical)."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:aiAgent a schema:DefinedTerm ;
    schema:name "AI Agent"@en ;
    schema:description "A machine actor that can read context, call tools, execute actions, and operate software without a human UI."@en ;
    owl:sameAs <https://www.linkedin.com/pulse/software-losing-its-head-seema-amble-6qmnc#aiAgent>,
        <https://www.unaligned.io/p/ai-agents-and-the-new-enterprise-workforce-layer#aiAgents> ;
    skos:altLabel "AI Agents"@en ;
    skos:related :agenticWeb, :agentIdentity, :modelContextProtocol ;
    rdfs:seeAlso <http://dbpedia.org/resource/Intelligent_agent> ;
