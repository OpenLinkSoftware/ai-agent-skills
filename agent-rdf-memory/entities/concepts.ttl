:semanticLayer a schema:DefinedTerm ;
    schema:name "Semantic Layer"@en ;
    schema:description "A data abstraction layer that defines metrics once and governs them centrally, enabling self-serve consumption without SQL — optimized for measurement and human consumption through BI tools."@en ;
    owl:sameAs <http://dbpedia.org/resource/Semantic_layer>,
        <https://metadataweekly.substack.com/p/ontologies-context-graphs-and-semantic#semanticLayer> ;
