:contextEngineering a schema:DefinedTerm ;
    schema:name "Context Engineering"@en ;
    schema:description "The discipline of designing a system that provides the right information and tools, in the right format, to give an LLM everything it needs to accomplish a task."@en ;
    owl:sameAs <https://metadataweekly.substack.com/p/ontologies-context-graphs-and-semantic#contextEngineering> ;
    skos:related :contextGraph, :knowledgeGraph, :aiAgent ;
