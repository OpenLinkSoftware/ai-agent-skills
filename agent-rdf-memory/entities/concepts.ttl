    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:agentIdentity a schema:DefinedTerm ;
    schema:name "Agent Identity"@en ;
    schema:description "The authorization model that determines whether an agent acts as itself, as a user, or both — the foundation for agent accountability and delegation."@en ;
    owl:sameAs <https://www.anthropic.com/engineering/how-we-contain-claude#term-agent-identity> ;
    skos:related :webid, :abac, :containment ;
    rdfs:comment "Recurred in 6 corpus documents. No verified external IRI; directly adjacent to this system's WebID/delegation practice (oplcert:hasIdentityDelegate, On-Behalf-Of)."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime .

:contextGraph a schema:DefinedTerm ;
    schema:name "Context Graph"@en ;
    schema:description "A knowledge graph capturing decision reasoning and operational context — answering 'Why was X allowed to happen?' rather than just 'What happened?' — including procedure specifications, execution histories, and agent roles."@en ;
    owl:sameAs <https://metadataweekly.substack.com/p/ontologies-context-graphs-and-semantic#contextGraph> ;
    skos:broader :knowledgeGraph ;
