<> a schema:CreativeWork ;
    schema:name "Entity Registry: Organizations"@en ;
    schema:description "Canonical schema:Organization entity IRIs for companies and institutions recurring across the agent RDF memory system. This is the authoritative single-source-of-truth — agents MUST consult this registry before resolving an organization entity, and MUST register newly resolved organization IRIs here rather than only in session files."@en ;
    schema:dateCreated "2026-07-08T00:00:00Z"^^xsd:dateTime ;
    schema:dateModified "2026-07-08T00:00:00Z"^^xsd:dateTime ;
