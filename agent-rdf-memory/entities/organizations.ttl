:openlinkSoftware a schema:Organization ;
    schema:name "OpenLink Software"@en ;
    schema:description "OpenLink Software, Inc. — creator of Virtuoso Universal Server, URIBurner, YouID, and the OPAL AI Layer. Provider of Linked Data, Semantic Web, and AI-agent infrastructure."@en ;
    schema:url "https://www.openlinksw.com/" ;
    owl:sameAs <http://dbpedia.org/resource/OpenLink_Software> ;
    rdfs:comment "Canonical entity IRI. DBpedia resource is the canonical form (verified via HTTP 200 dereference, 2026-07-08). First referenced in agent-rdf-memory/core.ttl as schema:author and schema:worksFor for Kingsley Uyi Idehen and agent identity. Also referenced in session files as prov:wasAttributedTo target."@en ;
    schema:dateCreated "2026-05-27T00:00:00Z"^^xsd:dateTime .
