@prefix : <#> .
@prefix schema: <http://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix irefde: <https://x.com/kidehen/status/2055725483535282591#> .
@prefix irefde2: <https://x.com/kidehen/status/2055725483535282591##> .
@prefix karp: <https://thecuberesearch.com/319-breaking-analysis-alex-karp-frontier-models-and-the-real-fight-for-enterprise-ai/#> .

<> a schema:CreativeWork, owl:Ontology ;
    schema:name "Entity Registry: TBox Alignment (Classes & Properties)"@en ;
    schema:description "OWL/RDFS alignment axioms harmonizing locally-minted TBox terms (rdfs:Class / owl:Class / rdf:Property) that were re-minted under disjoint IRIs across the published DAV corpus. Unlike entities/concepts.ttl (ABox-level schema:DefinedTerm instances aligned via owl:sameAs), this registry uses owl:equivalentClass / owl:equivalentProperty — the correct alignment vocabulary for TBox terms, and the form reasoners (Virtuoso inference rules, FuXi) can exploit to merge instance data across named graphs. Discovered via the TBox census of 2026-07-14: 656 locally-minted terms across DAV named graphs, 86 recurring in >= 2 documents. Loadable into Virtuoso as an alignment/inference graph."@en ;
    schema:dateCreated "2026-07-14T00:00:00Z"^^xsd:dateTime ;
    schema:dateModified "2026-07-14T00:00:00Z"^^xsd:dateTime ;
    schema:author <https://linkedin.com/in/kidehen#this> ;
    rdfs:seeAlso <../preferences.ttl>,
        <../howto/cross-document-local-term-reuse.ttl>,
        <../howto/ontology-cross-reference-gate.ttl>,
        <concepts.ttl> .

# ═══════════════════════════════════════════════════════════════════════════════
# ── 1. FDE/IRE Ontology: single-# vs double-## IRI repair ──────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
#
# The FDE/IRE Enterprise Skills ontology exists in the corpus under TWO IRI
# families caused by an @prefix declaration ending in "##" in one producing
# file (ire-fde-ontology-roles-claude_sonnet46-1.ttl) vs "#" in others.
# Census: single-# form appears in 5 graph loads, double-## in 2 → the
# single-# form is CANONICAL. Equivalence axioms below let reasoners treat
# instance data asserted against either family as one ontology. Future
# documents MUST bind irefde: to the single-# namespace.

# ── Classes (12) ──
irefde2:Skill owl:equivalentClass irefde:Skill .
irefde2:AILiteracySkill owl:equivalentClass irefde:AILiteracySkill .
irefde2:EngineeringRole owl:equivalentClass irefde:EngineeringRole .
irefde2:ForwardDeployedEngineer owl:equivalentClass irefde:ForwardDeployedEngineer .
irefde2:InwardRedeployedEngineer owl:equivalentClass irefde:InwardRedeployedEngineer .
irefde2:SkillLifecycleState owl:equivalentClass irefde:SkillLifecycleState .
irefde2:ProposedSkill owl:equivalentClass irefde:ProposedSkill .
irefde2:ValidatedSkill owl:equivalentClass irefde:ValidatedSkill .
irefde2:DeployedSkill owl:equivalentClass irefde:DeployedSkill .
irefde2:DeprecatedSkill owl:equivalentClass irefde:DeprecatedSkill .
irefde2:SkillGenerationActivity owl:equivalentClass irefde:SkillGenerationActivity .
irefde2:AgenticPod owl:equivalentClass irefde:AgenticPod .

# ── Properties (4) ──
irefde2:hasSkill owl:equivalentProperty irefde:hasSkill .
irefde2:requiresSkill owl:equivalentProperty irefde:requiresSkill .
irefde2:hasLifecycleState owl:equivalentProperty irefde:hasLifecycleState .
irefde2:createdFromTacitKnowledge owl:equivalentProperty irefde:createdFromTacitKnowledge .

# ═══════════════════════════════════════════════════════════════════════════════
# ── 2. Generator-Template Analysis Classes (cross-document re-mints) ──────────
# ═══════════════════════════════════════════════════════════════════════════════
#
# These generic analysis-pattern classes are minted by the kg-generator /
# rdf-infographic-skill workflow itself (not by any source article), so they
# recur under a fresh document-local IRI in every production run. The
# most-used IRI in the corpus is designated canonical; variants are aligned
# via owl:equivalentClass. Future doc-collection tasks MUST reuse the
# canonical IRI directly instead of minting another local one.

# ── KeyPrinciple — 5 documents, 5 disjoint IRIs (worst TBox re-mint in census) ──
:KeyPrinciple a owl:Class ;
    rdfs:label "Key Principle"@en ;
    rdfs:comment "A named principle or tenet extracted from an analyzed source document. Canonical corpus IRI for the generator-template analysis class re-minted in 5 documents (2026-07-14 census)."@en ;
    rdfs:isDefinedBy <> ;
    owl:equivalentClass <https://x.com/trq212/status/2052809885763747935#KeyPrinciple>,
        <https://thinkingmachines.ai/blog/interaction-models/#KeyPrinciple>,
        <https://joost.blog/agent-ready/#KeyPrinciple>,
        <https://abhiyadav.substack.com/p/what-is-an-audience-interest-graph/#KeyPrinciple>,
        <https://incidentdatabase.ai/blog/incident-report-2026-february-march-april/#KeyPrinciple> .

:KeyConcept a owl:Class ;
    rdfs:label "Key Concept"@en ;
    rdfs:comment "A named concept central to an analyzed source document. Canonical corpus IRI; 2 disjoint re-mints aligned."@en ;
    rdfs:isDefinedBy <> ;
    rdfs:seeAlso :KeyPrinciple ;
    owl:equivalentClass <https://www.linkedin.com/pulse/libraries-ai-infrastructure-african-edition-stuart-michael-edelenbos-bsage#KeyConcept>,
        <https://content.martechday.com/state-of-martech-2026.pdf#KeyConcept> .

:ComparisonDimension a owl:Class ;
    rdfs:label "Comparison Dimension"@en ;
    rdfs:comment "One axis of a structured comparison between two or more technologies, products, or approaches. Canonical corpus IRI; 2 disjoint re-mints aligned."@en ;
    rdfs:isDefinedBy <> ;
    owl:equivalentClass <https://neo4j.com/blog/graph-database/introducing-neo4j-virtual-graph-graph-reasoning-on-the-data-you-already-have/#ComparisonDimension>,
        <https://cloud.google.com/blog/products/data-analytics/how-the-open-knowledge-format-can-improve-data-sharing/#ComparisonDimension> .

:ArchitectureConcept a owl:Class ;
    rdfs:label "Architecture Concept"@en ;
    rdfs:comment "A named architectural concept or pattern discussed in an analyzed source. Canonical corpus IRI; 2 disjoint re-mints aligned."@en ;
    rdfs:isDefinedBy <> ;
    owl:equivalentClass <https://thinkingmachines.ai/blog/interaction-models/#ArchitectureConcept>,
        <https://www.linkedin.com/posts/tonyseale_every-c-suite-is-arriving-at-the-same-uncomfortable-share-7465730567645315073-O_VW#ArchitectureConcept> .

:ArchitecturalLayer a owl:Class ;
    rdfs:label "Architectural Layer"@en ;
    rdfs:comment "One layer in a layered architecture decomposition. Canonical corpus IRI; 2 disjoint re-mints aligned."@en ;
    rdfs:isDefinedBy <> ;
    rdfs:seeAlso :ArchitectureConcept ;
    owl:equivalentClass <https://diginomica.com/who-pays-agentic-ai-enterprise-budget-problem-no-vendor-will-address#ArchitecturalLayer>,
        <https://www.lassila.org/publications/2001/SciAm.pdf#ArchitecturalLayer> .

:UseCase a owl:Class ;
    rdfs:label "Use Case"@en ;
    rdfs:comment "A concrete usage scenario described in an analyzed source. Canonical corpus IRI; 2 disjoint re-mints aligned."@en ;
    rdfs:isDefinedBy <> ;
    owl:equivalentClass <https://x.com/trq212/status/2052809885763747935#UseCase>,
        <https://www.lassila.org/publications/2001/SciAm.pdf#UseCase> .

:Industry a owl:Class ;
    rdfs:label "Industry"@en ;
    rdfs:comment "An industry sector referenced in labor-TAM / automation-readiness analyses. Canonical corpus IRI; 3 disjoint re-mints aligned. Domain class for :hasLaborTAM and :hasAutomationReadiness."@en ;
    rdfs:isDefinedBy <> ;
    owl:equivalentClass <https://www.linkedin.com/posts/tonyseale_did-you-start-building-your-ontology-as-a-share-7463353332565356545-jY54#Industry>,
        <https://www.linkedin.com/pulse/sap-reinvents-its-ai-strategy-portfolio-autonomous-enterprise-smith-riqxc/#Industry>,
        <https://moderndata101.substack.com/p/the-semantic-medallion#Industry> .

:AgentSkill a owl:Class ;
    rdfs:label "Agent Skill"@en ;
    rdfs:comment "A packaged, reusable AI-agent capability (SKILL.md-style unit). Canonical corpus IRI; 2 disjoint re-mints aligned. Related to but distinct from irefde:Skill (the FDE/IRE lifecycle-governed enterprise skill artifact) — linked via rdfs:seeAlso pending an explicit subclass decision."@en ;
    rdfs:isDefinedBy <> ;
    rdfs:seeAlso irefde:Skill ;
    owl:equivalentClass <https://www.linkedin.com/pulse/china-built-super-app-us-may-build-super-agent-jaya-gupta-3ncoc/#AgentSkill>,
        <https://linkeddata.uriburner.com/DAV/demos/daas/youid-self-sovereign-identity-claude_sonnet_4_6-1.ttl#AgentSkill> .

:MultiModelDatabase a owl:Class ;
    rdfs:label "Multi-Model Database"@en ;
    rdfs:comment "A database engine supporting multiple data models (relational, graph, document, etc.) in one core. Canonical corpus IRI; 2 disjoint re-mints aligned."@en ;
    rdfs:isDefinedBy <> ;
    owl:equivalentClass <https://www.linkedin.com/pulse/china-built-super-app-us-may-build-super-agent-jaya-gupta-3ncoc/#MultiModelDatabase>,
        <https://neo4j.com/blog/graph-database/introducing-neo4j-virtual-graph-graph-reasoning-on-the-data-you-already-have/#MultiModelDatabase> .

:Event a owl:Class ;
    rdfs:label "Event"@en ;
    rdfs:comment "A scheduled event (conference, meetup, session). Canonical corpus IRI; 2 disjoint re-mints aligned. Consider schema:Event directly in future documents instead of any local class."@en ;
    rdfs:isDefinedBy <> ;
    rdfs:subClassOf <http://schema.org/Event> ;
    owl:equivalentClass <https://x.com/yumi_willems/status/2053256485124137228#Event>,
        <https://x.com/michelleefang/status/2053944163817898317#Event> .

:EventDay a owl:Class ;
    rdfs:label "Event Day"@en ;
    rdfs:comment "One day within a multi-day event program. Canonical corpus IRI; 2 disjoint re-mints aligned."@en ;
    rdfs:isDefinedBy <> ;
    rdfs:subClassOf :Event ;
    owl:equivalentClass <https://x.com/yumi_willems/status/2053256485124137228#EventDay>,
        <https://x.com/michelleefang/status/2053944163817898317#EventDay> .

# ── Reusable classes already correctly shared (advertised here for discovery) ──

karp:CriticalPerspective a rdfs:Class ;
    rdfs:label "Critical Perspective"@en ;
    rdfs:comment "A critical-response entry contesting or reframing an analyzed source's thesis. Minted once in the theCUBE Research Karp analysis KG and correctly REUSED by IRI (not re-minted) in reverse-information-paradox — the exemplar pattern this registry exists to enforce. Companion property: karp:respondsTo."@en ;
    rdfs:isDefinedBy <https://linkeddata.uriburner.com/DAV/demos/daas/karp-frontier-models-enterprise-ai-claude_sonnet_5-1.ttl> .

# ═══════════════════════════════════════════════════════════════════════════════
# ── 3. Generator-Template Analysis Properties (cross-document re-mints) ────────
# ═══════════════════════════════════════════════════════════════════════════════

:hasLaborTAM a rdf:Property ;
    rdfs:label "has labor TAM"@en ;
    rdfs:comment "Links an Industry to the total addressable market of labor exposed to AI automation within it. Canonical corpus IRI; 4 disjoint re-mints aligned (including the hasLaborTam casing variant)."@en ;
    rdfs:isDefinedBy <> ;
    rdfs:domain :Industry ;
    rdfs:range xsd:string ;
    owl:equivalentProperty <https://www.linkedin.com/posts/tonyseale_did-you-start-building-your-ontology-as-a-share-7463353332565356545-jY54#hasLaborTAM>,
        <https://www.forbes.com/sites/stevebanker/2026/05/16/palantir-says-saas-is-dead/#hasLaborTAM>,
        <https://moderndata101.substack.com/p/the-semantic-medallion#hasLaborTAM>,
        <https://benn.substack.com/p/what-will-startups-do-in-2030#hasLaborTam> .

:hasAutomationReadiness a rdf:Property ;
    rdfs:label "has automation readiness"@en ;
    rdfs:comment "Links an Industry to an assessment of how ready its workflows are for AI automation. Canonical corpus IRI; 4 disjoint re-mints aligned."@en ;
    rdfs:isDefinedBy <> ;
    rdfs:domain :Industry ;
    rdfs:range xsd:string ;
    owl:equivalentProperty <https://www.linkedin.com/posts/tonyseale_did-you-start-building-your-ontology-as-a-share-7463353332565356545-jY54#hasAutomationReadiness>,
        <https://www.forbes.com/sites/stevebanker/2026/05/16/palantir-says-saas-is-dead/#hasAutomationReadiness>,
        <https://moderndata101.substack.com/p/the-semantic-medallion#hasAutomationReadiness>,
        <https://benn.substack.com/p/what-will-startups-do-in-2030#hasAutomationReadiness> .

:dependsOn a rdf:Property ;
    rdfs:label "depends on"@en ;
    rdfs:comment "Links a component or layer to another it depends on. Canonical corpus IRI; 2 disjoint re-mints aligned."@en ;
    rdfs:isDefinedBy <> ;
    owl:equivalentProperty <https://moderndata101.substack.com/p/the-semantic-medallion#dependsOn>,
        <https://www.lassila.org/publications/2001/SciAm.pdf#dependsOn> .

:enablesCapability a rdf:Property ;
    rdfs:label "enables capability"@en ;
    rdfs:comment "Links a technology or layer to a capability it enables. Canonical corpus IRI; 2 disjoint re-mints aligned."@en ;
    rdfs:isDefinedBy <> ;
    owl:equivalentProperty <https://moderndata101.substack.com/p/the-semantic-medallion#enablesCapability>,
        <https://www.lassila.org/publications/2001/SciAm.pdf#enablesCapability> .

:demonstrates a rdf:Property ;
    rdfs:label "demonstrates"@en ;
    rdfs:comment "Links an example or case to the principle it demonstrates. Canonical corpus IRI; 2 disjoint re-mints aligned."@en ;
    rdfs:isDefinedBy <> ;
    owl:equivalentProperty <https://leestack.dev/writing/nasa-rules-for-code-that-cant-fail#demonstrates>,
        <https://lilyraynyc.substack.com/p/the-ai-slop-loop#demonstrates> .

# ═══════════════════════════════════════════════════════════════════════════════
# ── 4. Watchlist: label collisions that are NOT identity (do not align) ────────
# ═══════════════════════════════════════════════════════════════════════════════
#
# The census surfaced these same-label clusters that must NOT receive
# owl:equivalentClass/equivalentProperty — the shared label masks genuinely
# different terms. Recorded so a future census pass doesn't 'fix' them:
#
#   - 'status'/'name'/'email'/'customerId': the truck-ontology-bench properties
#     (truckStatus, driverStatus, loadStatus, customerName, driverEmail, ...)
#     are domain-scoped and disjoint from the semantic-medallion generic
#     properties sharing the label fragment. Different domains, different
#     semantics — alignment would corrupt inference.
#   - 'Customer': moderndata101#Customer (data-product consumer) vs
#     truck-ontology#Customer (freight customer) — same label, different
#     ontological commitments. rdfs:seeAlso at most, never equivalence.
#   - 'Concept' / 'Technology': too generic to assert identity across
#     documents without inspecting instance usage; leave unaligned.
