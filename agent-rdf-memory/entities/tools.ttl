@prefix : <#> .
@prefix schema: <http://schema.org/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix dbr: <http://dbpedia.org/resource/> .
@prefix dbo: <http://dbpedia.org/ontology/> .

<> a schema:CreativeWork ;
    schema:name "Entity Registry: Tools & Software"@en ;
    schema:description "Canonical schema:SoftwareApplication and schema:SoftwareSourceCode entity IRIs for skills, LLM models, agent environments, and recurring software products across the agent RDF memory system. This is the authoritative single-source-of-truth — agents MUST consult this registry before resolving a tool or software entity."@en ;
    schema:dateCreated "2026-07-08T00:00:00Z"^^xsd:dateTime ;
    schema:dateModified "2026-07-08T00:00:00Z"^^xsd:dateTime ;
    schema:author <https://linkedin.com/in/kidehen#this> ;
    schema:about :kgGeneratorSkill, :rdfInfographicSkill,
        :claudeSonnet, :gpt5ChatCodex, :deepseekV4Pro, :grok43,
        :bigPickle, :glm, :kimi, :minimax, :qwen,
        :claudeCodeEnv, :openCodeEnv, :chatCodexEnv, :grokCliEnv,
        :virtuoso, :uriburner, :opal ;
    rdfs:seeAlso <../preferences.ttl>, <../core.ttl>,
        <../howto/canonical-entity-iri-denotation.ttl> .

# ═══════════════════════════════════════════════════════════════════════════════
