# ── Virtuoso Universal Server ──────────────────────────────────────────────────

:virtuoso a schema:SoftwareApplication ;
    schema:name "Virtuoso Universal Server"@en ;
    schema:description "OpenLink Software's multi-model database engine and middleware platform. Provides SQL, SPARQL, RDF, and GraphQL capabilities with built-in WebDAV, SPARQL endpoint, and RDF sponging."@en ;
    schema:url "https://virtuoso.openlinksw.com/" ;
    owl:sameAs <http://dbpedia.org/resource/Virtuoso_Universal_Server> ;
    rdfs:comment "Canonical entity IRI. DBpedia resource (verified HTTP 200, 2026-07-08). Recurring entity across session files as SPARQL endpoint target and RDF infrastructure."@en ;
    schema:dateCreated "2026-06-02T00:00:00Z"^^xsd:dateTime .

# ── URIBurner ──────────────────────────────────────────────────────────────────

:uriburner a schema:SoftwareApplication ;
    schema:name "URIBurner"@en ;
    schema:description "OpenLink Software's Linked Data generator and SPARQL endpoint service. Provides RDF sponging, entity description, and linked-data meshup capabilities at linkeddata.uriburner.com."@en ;
    schema:url "https://linkeddata.uriburner.com/" ;
    owl:sameAs <https://linkeddata.uriburner.com/#this> ;
    rdfs:comment "Canonical entity IRI. Service homepage + #this convention. Recurring entity across session files as the default WebDAV upload target, SPARQL endpoint, and resolver service."@en ;
    schema:dateCreated "2026-06-02T00:00:00Z"^^xsd:dateTime .

# ── OPAL (OpenLink AI Layer) ───────────────────────────────────────────────────

:opal a schema:SoftwareApplication ;
    schema:name "OPAL"@en ;
    schema:description "OpenLink AI Layer — OpenLink Software's AI-agent framework providing MCP Tools, multi-LLM routing, Skills/Agents, and Vector Store integration within Virtuoso."@en ;
    schema:url "https://www.openlinksw.com/opal/" ;
    owl:sameAs <https://www.openlinksw.com/ontology/opal/#this> ;
    rdfs:comment "Canonical entity IRI. OPAL ontology namespace + #this convention. Referenced in agent-rdf-memory/ontology.ttl and session files as the analytics vocabulary provider (opal:ChatSession, opal:ChatModel, etc.)."@en ;
    schema:dateCreated "2026-06-24T00:00:00Z"^^xsd:dateTime .
