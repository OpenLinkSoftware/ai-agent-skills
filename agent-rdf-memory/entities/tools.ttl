    rdfs:comment "Canonical entity IRI. Product page + #this convention. Referenced as the 'chat-codex' agent environment in session filenames (e.g., 2026-05-28-gpt5_chat-codex.ttl)."@en ;
    schema:dateCreated "2026-05-28T00:00:00Z"^^xsd:dateTime .

:grokCliEnv a schema:SoftwareApplication ;
