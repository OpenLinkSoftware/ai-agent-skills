# ═══════════════════════════════════════════════════════════════════════════════

# ── kg-generator skill ─────────────────────────────────────────────────────────
#
# Canonical IRI: https://github.com/OpenLinkSoftware/ai-agent-skills/tree/main/kg-generator#this
# First resolved in: sessions/2026-05-27.ttl (earliest session)
# Appears in 40+ session files under prov:wasGeneratedBy, schema:instrument

:kgGeneratorSkill a schema:SoftwareApplication ;
    schema:name "kg-generator"@en ;
    schema:description "AI agent skill that generates comprehensive Knowledge Graphs (RDF-Turtle by default, or JSON-LD) from content at file: or http(s): scheme URLs. Part of the OpenLinkSoftware ai-agent-skills repository."@en ;
    schema:url "https://github.com/OpenLinkSoftware/ai-agent-skills/tree/main/kg-generator" ;
    owl:sameAs <https://github.com/OpenLinkSoftware/ai-agent-skills/tree/main/kg-generator#this> ;
    rdfs:comment "Canonical entity IRI. GitHub repository path + #this fragment per SoftwareApplication IRI convention. First referenced in sessions/2026-05-27.ttl and appears as prov:wasGeneratedBy target in 40+ session files."@en ;
    schema:dateCreated "2026-05-27T00:00:00Z"^^xsd:dateTime .

# ── rdf-infographic-skill ──────────────────────────────────────────────────────
#
# Canonical IRI: https://github.com/OpenLinkSoftware/ai-agent-skills/tree/main/rdf-infographic-skill#this
# First resolved in: sessions/2026-05-27.ttl (earliest session)
# Appears in 40+ session files under prov:wasGeneratedBy, schema:instrument

:rdfInfographicSkill a schema:SoftwareApplication ;
    schema:name "rdf-infographic-skill"@en ;
    schema:description "AI agent skill that generates sophisticated, interactive HTML infographics from RDF data in any format. Part of the OpenLinkSoftware ai-agent-skills repository."@en ;
    schema:url "https://github.com/OpenLinkSoftware/ai-agent-skills/tree/main/rdf-infographic-skill" ;
    owl:sameAs <https://github.com/OpenLinkSoftware/ai-agent-skills/tree/main/rdf-infographic-skill#this> ;
    rdfs:comment "Canonical entity IRI. GitHub repository path + #this fragment per SoftwareApplication IRI convention. First referenced in sessions/2026-05-27.ttl and appears as prov:wasGeneratedBy target in 40+ session files."@en ;
    schema:dateCreated "2026-05-27T00:00:00Z"^^xsd:dateTime .

# ═══════════════════════════════════════════════════════════════════════════════
# ── LLM Models ────────────────────────────────────────────────────────────────
# ═══════════════════════════════════════════════════════════════════════════════
#
# Priority ladder for LLM models: DBpedia → Wikidata → Provider homepage #this
# Most LLM models lack DBpedia/Wikidata entries; the provider homepage + #this
# convention is used as the canonical IRI. These IRIs are naming conventions —
# many provider homepages block automated dereference (403). schema:version
# differentiates model variants sharing the same product IRI.

# ── Claude (Sonnet 4.6, Sonnet 5, Opus 4.7/4.8) ───────────────────────────────

:claudeSonnet a schema:SoftwareApplication ;
    schema:name "Claude"@en ;
    schema:description "Anthropic's Claude AI model family. Multiple versions have been used across sessions: Claude Sonnet 4.6, Claude Sonnet 5, Claude Opus 4.7, Claude Opus 4.8."@en ;
    schema:url "https://claude.ai/" ;
    owl:sameAs <https://claude.ai/#this> ;
    rdfs:comment "Canonical entity IRI. Provider homepage + #this convention per SoftwareApplication priority ladder (no DBpedia/Wikidata entry). Anthropic's product homepage blocks automated dereference (HTTP 403) — the IRI is a naming convention, not a dereferenceable endpoint. Individual model versions are identified by schema:version."@en ;
    schema:dateCreated "2026-05-27T00:00:00Z"^^xsd:dateTime .

