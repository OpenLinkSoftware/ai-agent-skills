:claudeCodeEnv a schema:SoftwareApplication ;
    schema:name "Claude Code"@en ;
    schema:description "Anthropic's Claude Code CLI — the agent environment/harness that hosts Claude models for task execution. The most common agent environment across session files."@en ;
    schema:url "https://claude.ai/code" ;
    owl:sameAs <https://claude.ai/code#this> ;
    rdfs:comment "Canonical entity IRI. Product page + #this convention. Referenced as the 'Claude Code' agent environment in session filenames and core.ttl agent identity template."@en ;
    schema:dateCreated "2026-05-27T00:00:00Z"^^xsd:dateTime .

:openCodeEnv a schema:SoftwareApplication ;
    schema:name "OpenCode"@en ;
    schema:description "OpenCode AI agent environment — hosts Big Pickle, GLM, kimi, MiniMax, and Qwen models."@en ;
    schema:url "https://opencode.ai/" ;
    owl:sameAs <https://opencode.ai/#this> ;
    rdfs:comment "Canonical entity IRI. Product page + #this convention. Referenced as the 'opencode' agent environment in session filenames (e.g., 2026-06-03-big_pickle-opencode.ttl). The owl:sameAs target https://opencode.ai/#this appears in multiple session files."@en ;
    schema:dateCreated "2026-05-27T00:00:00Z"^^xsd:dateTime .

:chatCodexEnv a schema:SoftwareApplication ;
