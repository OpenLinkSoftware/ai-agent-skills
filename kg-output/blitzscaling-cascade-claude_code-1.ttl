:BlitzscalingBet a rdfs:Class ;
    rdfs:label "Blitzscaling Bet"@en ;
    rdfs:comment "A growth strategy prioritizing speed-to-capability over efficient engineering, assuming efficiency can be retrofitted after scale is captured."@en ;
    rdfs:isDefinedBy : ;
    rdfs:seeAlso <http://dbpedia.org/resource/Blitzscaling> ;
    rdfs:subClassOf :CausalStage .

:CapexConsequence a rdfs:Class ;
    rdfs:label "Capex Consequence"@en ;
    rdfs:comment "A stage where a scaling bet materializes as concentrated capital expenditure and balance-sheet exposure for infrastructure providers."@en ;
    rdfs:isDefinedBy : ;
    rdfs:seeAlso <http://dbpedia.org/resource/Capital_expenditure> ;
    rdfs:subClassOf :CausalStage .

:CausalStage a rdfs:Class ;
    rdfs:label "Causal Stage"@en ;
    rdfs:comment "One stage in a multi-document causal chain linking a strategic bet to its downstream market consequences."@en ;
    rdfs:isDefinedBy : ;
    rdfs:seeAlso <http://dbpedia.org/resource/Causality> .

:CommoditizationDisruption a rdfs:Class ;
    rdfs:label "Commoditization Disruption"@en ;
    rdfs:comment "A stage where a cheaper 'scale-out' alternative undercuts an expensive 'scale-up' incumbent approach, per the historical mainframe-to-mobile / big-iron-to-internet pattern."@en ;
    rdfs:isDefinedBy : ;
    rdfs:seeAlso <http://dbpedia.org/resource/Commoditization>,
        <http://dbpedia.org/resource/Disruptive_innovation> ;
    rdfs:subClassOf :CausalStage .

:CostExternalization a rdfs:Class ;
    rdfs:label "Cost Externalization"@en ;
    rdfs:comment "A stage where the unit-cost consequence of a scaling bet is pushed onto a shared external market rather than absorbed internally."@en ;
    rdfs:isDefinedBy : ;
    rdfs:seeAlso <http://dbpedia.org/resource/Externality> ;
    rdfs:subClassOf :CausalStage .

:SourceAnalysis a rdfs:Class ;
    rdfs:label "Source Analysis"@en ;
    rdfs:comment "One of the three published analyses synthesized into this mashup."@en ;
    rdfs:isDefinedBy : ;
    rdfs:subClassOf schema:CreativeWork .

:cascadesTo a rdf:Property ;
    rdfs:label "cascades to"@en ;
    rdfs:comment "Links a causal stage to the next stage it produces or enables."@en ;
    rdfs:domain :CausalStage ;
    rdfs:isDefinedBy : ;
    rdfs:range :CausalStage ;
    rdfs:seeAlso <http://dbpedia.org/resource/Causality> .

:evidencedBy a rdf:Property ;
    rdfs:label "evidenced by"@en ;
    rdfs:comment "Links a causal stage to the source analysis that documents it."@en ;
    rdfs:domain :CausalStage ;
    rdfs:isDefinedBy : ;
    rdfs:range :SourceAnalysis ;
    rdfs:seeAlso schema:citation .

:externalizesCostOnto a rdf:Property ;
    rdfs:label "externalizes cost onto"@en ;
    rdfs:comment "Links a strategic bet to the shared market or resource pool absorbing its unit-cost consequence."@en ;
    rdfs:domain :BlitzscalingBet ;
    rdfs:isDefinedBy : ;
    rdfs:seeAlso <http://dbpedia.org/resource/Externality> .

:invertsReturnsOf a rdf:Property ;
    rdfs:label "inverts returns of"@en ;
    rdfs:comment "Asserts that a scaling approach produces rising, not falling, marginal cost relative to a comparison approach."@en ;
    rdfs:isDefinedBy : ;
    rdfs:seeAlso <http://dbpedia.org/resource/Diminishing_returns> .

