    schema:acceptedAnswer :a5 ;
    schema:isPartOf :faqSection ;
    schema:name "What is the circular-revenue risk in Microsoft's OpenAI relationship?"@en .

:q6 a schema:Question ;
    schema:acceptedAnswer :a6 ;
    schema:isPartOf :faqSection ;
    schema:name "What is the real binding constraint on hyperscaler AI capex?"@en .

:q7 a schema:Question ;
    schema:acceptedAnswer :a7 ;
    schema:isPartOf :faqSection ;
    schema:name "What event exposed the fragility of the scale-up bet?"@en .

:q8 a schema:Question ;
    schema:acceptedAnswer :a8 ;
    schema:isPartOf :faqSection ;
    schema:name "How does Steven Sinofsky frame DeepSeek's emergence as inevitable?"@en .

