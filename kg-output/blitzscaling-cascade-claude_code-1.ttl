:stage1BlitzscalingBet a :BlitzscalingBet ;
    schema:about <http://dbpedia.org/resource/Blitzscaling>,
        <http://dbpedia.org/resource/Ilya_Sutskever> ;
    schema:description "Ilya Sutskever's framing of brute-force scaling as 'a very low-risk way of investing your resources' mirrors blitzscaling's core logic: prioritize speed-to-capability over efficient engineering, with scaling laws serving as ideological cover for unresolved quadratic-cost inefficiency."@en ;
    schema:isPartOf :analysis ;
    schema:name "Frontier Labs' Brute-Force Scaling Bet"@en ;
    :cascadesTo :stage2CostExternalization ;
    :evidencedBy <https://www.theatlantic.com/technology/2026/07/generative-ai-engineering-disaster/687901/> .

:step1 a schema:HowToStep ;
    schema:isPartOf :howtoSection ;
    schema:name "Identify the strategic bet"@en ;
    schema:text "Locate the growth-over-efficiency choice at the root of the cascade: frontier labs treating brute-force compute scaling as low-risk, per Sutskever's framing and the Blitzscaling playbook."@en .

:step2 a schema:HowToStep ;
    schema:isPartOf :howtoSection ;
    schema:name "Check whether returns are rising or falling"@en ;
    schema:text "Verify the scaling law in play. If unit cost falls with scale (true blitzscaling), the bet is sound. If it scales quadratically like LLM training, returns invert."@en .

:step3 a schema:HowToStep ;
    schema:isPartOf :howtoSection ;
    schema:name "Trace where the cost lands"@en ;
    schema:text "Follow the externalized cost onto the shared market — memory supply, hardware prices, data-center buildout — rather than assuming it stays contained to the lab making the bet."@en .

:step4 a schema:HowToStep ;
    schema:isPartOf :howtoSection ;
    schema:name "Quantify the balance-sheet exposure"@en ;
    schema:text "Examine the infrastructure provider's true economic obligations, capex run-rate, and backlog concentration — e.g., Microsoft's $226.5B obligations and ~45% OpenAI-backlog concentration."@en .

:step5 a schema:HowToStep ;
    schema:isPartOf :howtoSection ;
    schema:name "Locate the actual binding constraint"@en ;
    schema:text "Distinguish the constraint that capital cannot solve — here, electricity/grid capacity — from the one everyone is watching, capital availability."@en .

:step6 a schema:HowToStep ;
    schema:isPartOf :howtoSection ;
    schema:name "Watch for the disruption signal"@en ;
    schema:text "Identify the shock event confirming the disruption thesis — e.g., Nvidia's $593B single-day loss on the DeepSeek news."@en .

:step7 a schema:HowToStep ;
    schema:isPartOf :howtoSection ;
    schema:name "Apply the historical pattern"@en ;
    schema:text "Map the event onto the recurring scale-up-to-scale-out cycle (mainframe to mobile, big iron to internet) to judge whether the disruption is a one-off or, per Sinofsky, inevitable."@en .

:stevenSinofsky a schema:Person ;
    schema:name "Steven Sinofsky"@en .

:termBlitzscaling a schema:DefinedTerm,
        skos:Concept ;
    schema:description "Reid Hoffman and Chris Yeh's growth framework: prioritizing speed over efficiency in winner-take-most markets, assuming efficiency can be retrofitted after scale is captured."@en ;
    schema:name "Blitzscaling"@en ;
    skos:inScheme :glossarySection .

:termCircularRevenue a schema:DefinedTerm,
        skos:Concept ;
    schema:description "Revenue concentrated in a customer relationship where the infrastructure provider's growth and the customer's spending are mutually dependent, as with Microsoft's Azure backlog and OpenAI."@en ;
    schema:name "Circular Revenue"@en ;
    skos:inScheme :glossarySection .

:termComputeMultiplier a schema:DefinedTerm,
        skos:Concept ;
    schema:description "Dario Amodei's vaguely defined term for techniques claimed to improve AI model efficiency, without public evidence that quadratic scaling has been solved."@en ;
    schema:name "Compute Multiplier"@en ;
    skos:inScheme :glossarySection .

:termCostExternalization a schema:DefinedTerm,
        skos:Concept ;
    schema:description "Pushing the unit-cost consequence of a strategic bet onto a shared external market — here, the global memory and hardware supply chain — rather than absorbing it internally."@en ;
    schema:name "Cost Externalization"@en ;
    skos:inScheme :glossarySection .

:termDeepSeekShock a schema:DefinedTerm,
        skos:Concept ;
    schema:description "The market reaction — including Nvidia's $593 billion single-day loss, the largest in US equity history — to DeepSeek demonstrating comparable model capability at dramatically lower training cost."@en ;
    schema:name "DeepSeek Shock"@en ;
    skos:inScheme :glossarySection .

:termGridConstraint a schema:DefinedTerm,
        skos:Concept ;
    schema:description "The physical limit on available electricity supply that caps further AI data-center buildout regardless of available capital."@en ;
    schema:name "Grid Constraint"@en ;
    skos:inScheme :glossarySection .

:termInnovatorsDilemma a schema:DefinedTerm,
        skos:Concept ;
    schema:description "Clayton Christensen's framework describing how incumbents optimizing within an existing paradigm are structurally blind to cheaper disruptive alternatives emerging beneath them."@en ;
    schema:name "Innovator's Dilemma"@en ;
    skos:inScheme :glossarySection .

:termQuadraticScaling a schema:DefinedTerm,
        skos:Concept ;
    schema:description "A cost-growth pattern where the resource cost of processing input grows disproportionately faster than the input itself, as opposed to efficient logarithmic scaling."@en ;
    schema:name "Quadratic Scaling"@en ;
    skos:inScheme :glossarySection .

:termScaleOut a schema:DefinedTerm,
        skos:Concept ;
    schema:description "A cheaper, distributed approach that historically displaces scale-up incumbents once it matures — e.g., minicomputers, the internet, DeepSeek's commodity-hardware training."@en ;
    schema:name "Scale-Out"@en ;
    skos:inScheme :glossarySection .

:termScaleUp a schema:DefinedTerm,
        skos:Concept ;
    schema:description "An expensive, centralized approach to a technology cycle — e.g., mainframes, big iron, today's massive-capex frontier model training."@en ;
    schema:name "Scale-Up"@en ;
    skos:inScheme :glossarySection .

