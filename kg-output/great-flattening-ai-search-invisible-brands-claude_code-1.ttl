#################################################################
# Lightweight Ontology
#################################################################

: a owl:Ontology ;
    schema:name "AI Search Visibility Ontology"@en ;
    schema:description "A lightweight ontology for modeling studies, findings, and organizations relevant to AI-generative-engine content citation and visibility analysis."@en ;
    schema:identifier <https://www.thestateofbrand.com/news/great-flattening-ai-search-invisible-brands> ;
    rdfs:label "AI Search Visibility Ontology"@en ;
    rdfs:comment "Supports the analysis of 'The Great Flattening', the homogenization of AI-generated content and its effect on citation by generative search/answer engines."@en .

:AIVisibilityStudy a rdfs:Class ;
    rdfs:label "AI Visibility Study"@en ;
    rdfs:comment "A research study measuring how content is cited, ranked, or converted by AI-driven search or answer engines."@en ;
    rdfs:isDefinedBy : .

:CitationStudy a rdfs:Class ;
    rdfs:subClassOf :AIVisibilityStudy ;
    rdfs:label "Citation Study"@en ;
    rdfs:comment "A study measuring which sources are cited by generative AI engines and how citation overlaps with traditional search ranking."@en ;
    rdfs:isDefinedBy : .

:ConversionStudy a rdfs:Class ;
    rdfs:subClassOf :AIVisibilityStudy ;
    rdfs:label "Conversion Study"@en ;
    rdfs:comment "A study measuring traffic or conversion outcomes attributable to AI-driven referrals."@en ;
    rdfs:isDefinedBy : .

:hasSampleSize a rdf:Property ;
    rdfs:label "has sample size"@en ;
    rdfs:comment "The size or scope of the dataset analyzed by an AI visibility study."@en ;
    rdfs:domain :AIVisibilityStudy ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy : .

:hasKeyFinding a rdf:Property ;
    rdfs:label "has key finding"@en ;
    rdfs:comment "A principal finding or statistic reported by an AI visibility study."@en ;
    rdfs:domain :AIVisibilityStudy ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy : .

#################################################################
# Main Article
#################################################################

:analysis a schema:Article ;
    schema:headline "80% of What ChatGPT Cites Doesn't Rank on Google. The Great Flattening Just Got a Price Tag."@en ;
    schema:name "The Great Flattening: AI Search and Invisible Brands"@en ;
    schema:url <https://www.thestateofbrand.com/news/great-flattening-ai-search-invisible-brands> ;
    schema:datePublished "2026-07-12"^^xsd:date ;
    schema:publisher :stateOfBrand ;
    schema:articleSection "Growth & Strategy"@en, "AI & Technology"@en ;
    schema:abstract "AI-generated averaged content is becoming invisible to generative search engines: 80% of URLs ChatGPT cites most do not rank in Google's top 100, and undifferentiated content is never cited regardless of volume."@en ;
    schema:about :sectionMachineCantCite, :sectionContentLoop, :sectionCompaniesEnginesChoose, :sectionRetrievalTest, :section955Rule ;
    schema:hasPart :sectionMachineCantCite, :sectionContentLoop, :sectionCompaniesEnginesChoose, :sectionRetrievalTest, :section955Rule,
                    :faqSection, :glossarySection, :howtoSection, : ;
    prov:wasGeneratedBy <https://github.com/OpenLinkSoftware/ai-agent-skills/tree/main/kg-generator#this> .

:stateOfBrand a schema:Organization ;
    schema:name "State of Brand"@en ;
    schema:url <https://www.thestateofbrand.com/> ;
    schema:identifier "https://www.thestateofbrand.com/"^^xsd:anyURI .

<https://github.com/OpenLinkSoftware/ai-agent-skills/tree/main/kg-generator#this> a schema:SoftwareApplication ;
    schema:name "kg-generator skill"@en ;
    schema:url <https://github.com/OpenLinkSoftware/ai-agent-skills/tree/main/kg-generator> ;
    schema:description "An AI agent skill that generates comprehensive RDF/JSON-LD Knowledge Graphs from web content using schema.org and lightweight custom ontologies."@en .

#################################################################
# Article Sections
#################################################################

:sectionMachineCantCite a schema:CreativeWork ;
    schema:name "The machine can't cite what it can't tell apart"@en ;
    schema:isPartOf :analysis ;
    schema:about :ahrefsStudy, :profoundStudy, :whitehatStudy, :termBrandMention ;
    schema:text "Companies relying on AI-generated averaged content become invisible to AI search engines because such content lacks the distinguishing characteristics generative models need in order to cite it."@en .

:sectionContentLoop a schema:CreativeWork ;
    schema:name "The loop tightening inside content teams right now"@en ;
    schema:isPartOf :analysis ;
    schema:about :termContentLoop ;
    schema:text "Teams generating high-volume AI content produce fluent but undifferentiated material that engines never cite, prompting them to increase volume further and tighten an ineffective cycle."@en .

:sectionCompaniesEnginesChoose a schema:CreativeWork ;
    schema:name "The companies the engines keep choosing"@en ;
    schema:isPartOf :analysis ;
    schema:about :adobeStudy, :clarityStudy ;
    schema:text "AI-driven referral traffic and conversion rates are concentrating around a small set of companies whose content is distinctive enough to be cited by generative engines."@en .

:sectionRetrievalTest a schema:CreativeWork ;
    schema:name "Run the retrieval test"@en ;
    schema:isPartOf :analysis ;
    schema:about :retrievalStudy, :termRetrievalTest ;
    schema:text "Readers are urged to test their AI search visibility directly by asking ChatGPT, Perplexity, and Gemini the questions their target buyers ask, then counting appearances."@en .

:section955Rule a schema:CreativeWork ;
    schema:name "The 95-5 rule just acquired a machine"@en ;
    schema:isPartOf :analysis ;
    schema:about :term955Rule, :ehrenbergBassInstitute ;
    schema:text "Ehrenberg-Bass's 95-5 rule, describing the small share of buyers actively in-market at any time, now interacts with generative engines that decide which brands those in-market buyers ever see."@en .

:analysis schema:hasPart :sectionMachineCantCite .
:sectionMachineCantCite schema:isPartOf :analysis .

#################################################################
# Studies (Ontology Instances)
#################################################################

:ahrefsStudy a :CitationStudy ;
    schema:name "Ahrefs AI citation analysis"@en ;
    schema:creator :ahrefs ;
    schema:about :sectionMachineCantCite ;
    :hasSampleSize "75,000 brands analyzed across ChatGPT, Google AI Mode, and AI Overviews"@en ;
    :hasKeyFinding "80% of the URLs ChatGPT cites most do not rank in Google's top 100 results; brand mentions predicted AI visibility three times more strongly than backlinks."@en .

:profoundStudy a :CitationStudy ;
    schema:name "Profound citation study"@en ;
    schema:creator :profound ;
    schema:about :sectionMachineCantCite ;
    :hasSampleSize "680 million citations analyzed"@en ;
    :hasKeyFinding "28% of ChatGPT's most-cited pages have zero Google organic visibility."@en .

:whitehatStudy a :CitationStudy ;
    schema:name "Whitehat SEO cross-engine citation study"@en ;
    schema:creator :whitehatSEO ;
    schema:about :sectionMachineCantCite ;
    :hasSampleSize "118,000 responses analyzed"@en ;
    :hasKeyFinding "Only roughly 11% overlap exists between what ChatGPT and Perplexity cite."@en .

:adobeStudy a :ConversionStudy ;
    schema:name "Adobe holiday-season AI referral traffic study"@en ;
    schema:creator :adobe ;
    schema:about :sectionCompaniesEnginesChoose ;
    :hasKeyFinding "AI-driven referral traffic to US retail sites rose nearly 700% year-over-year during the 2025 holiday season, exceeding one trillion visits."@en .

:clarityStudy a :ConversionStudy ;
    schema:name "Microsoft Clarity referral conversion study"@en ;
    schema:creator :microsoft ;
    schema:about :sectionCompaniesEnginesChoose ;
    :hasSampleSize "1,277 sites studied over 8 months"@en ;
    :hasKeyFinding "Copilot referrals convert to subscriptions at 17 times the rate of direct traffic."@en .

:retrievalStudy a schema:ScholarlyArticle ;
    schema:name "Retrieval-test study of generative engine citation behavior"@en ;
    schema:url <https://arxiv.org/pdf/2311.09735> ;
    schema:contributor :princeton, :georgiaTech, :iitDelhi ;
    schema:about :sectionRetrievalTest ;
    :hasSampleSize "10,000 queries run through generative engines"@en .

