  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#stage3CapexConsequence",
    "@type": [
      "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#CapexConsequence"
    ],
    "http://schema.org/about": [
      {
        "@id": "http://dbpedia.org/resource/Microsoft"
      },
      {
        "@id": "http://dbpedia.org/resource/OpenAI"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Microsoft alone reports true economic obligations of ~$226.5 billion (5x reported long-term debt), $37.5 billion in single-quarter capex, and a $625 billion commercial backlog ~45% concentrated in OpenAI, a customer projected to burn $12-15 billion in 2026 operating losses. The binding constraint is not capital but the electricity grid."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#analysis"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Hyperscaler Capex Explosion and Circular Revenue Exposure"
      }
    ],
    "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#cascadesTo": [
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#stage4CommoditizationDisruption"
      }
    ],
    "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#evidencedBy": [
      {
        "@id": "https://shanakaanslemperera.substack.com/p/microsofts-226-billion-shadow"
      }
    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#stage4CommoditizationDisruption",
    "@type": [
      "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#CommoditizationDisruption"
    ],
    "http://schema.org/about": [
      {
        "@id": "http://dbpedia.org/resource/DeepSeek"
      },
      {
        "@id": "http://dbpedia.org/resource/Nvidia"
      }
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "DeepSeek's commodity-hardware, open approach delivered comparable results at a fraction of the cost, triggering Nvidia's $593 billion single-day loss — the largest in US equity history — and confirming the historical pattern (mainframe to mobile, big iron to internet) that cheaper 'scale-out' alternatives eventually replace expensive 'scale-up' incumbents."
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#analysis"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "DeepSeek's Scale-Out Commoditization"
      }
    ],
