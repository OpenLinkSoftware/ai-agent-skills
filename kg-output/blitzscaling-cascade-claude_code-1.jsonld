        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#faqSection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Why does quadratic LLM scaling break the blitzscaling playbook?"
      }
    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#evidencedBy",
    "@type": [
