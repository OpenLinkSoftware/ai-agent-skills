      }
    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#step6",
    "@type": [
      "http://schema.org/HowToStep"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#howtoSection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Watch for the disruption signal"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Identify the shock event confirming the disruption thesis — e.g., Nvidia's $593B single-day loss on the DeepSeek news."
      }
    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#a4",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Approximately $226.5 billion — more than five times its reported long-term debt of $43.2 billion — driven substantially by AI infrastructure commitments."
      }
    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#termScaleOut",
    "@type": [
      "http://schema.org/DefinedTerm",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A cheaper, distributed approach that historically displaces scale-up incumbents once it matures — e.g., minicomputers, the internet, DeepSeek's commodity-hardware training."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Scale-Out"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#glossarySection"
      }
    ]
  },
  {
