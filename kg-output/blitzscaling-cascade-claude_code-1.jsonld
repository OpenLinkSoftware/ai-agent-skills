  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#termQuadraticScaling",
    "@type": [
      "http://schema.org/DefinedTerm",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "A cost-growth pattern where the resource cost of processing input grows disproportionately faster than the input itself, as opposed to efficient logarithmic scaling."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Quadratic Scaling"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
