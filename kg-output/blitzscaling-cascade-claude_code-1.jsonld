  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#stage2CostExternalization",
    "@type": [
      "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#CostExternalization"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Classic blitzscaling externalizes cost onto competitors or investors; frontier labs externalize theirs onto the whole computing market — AI firms may be buying 70% of the world's high-end memory, hard-drive prices rose from $350 to $800 in two years, and US data-center capacity is being expanded roughly eightfold."
      }
    ],
