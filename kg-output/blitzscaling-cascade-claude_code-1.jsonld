  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#step7",
    "@type": [
      "http://schema.org/HowToStep"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#howtoSection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Apply the historical pattern"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Map the event onto the recurring scale-up-to-scale-out cycle (mainframe to mobile, big iron to internet) to judge whether the disruption is a one-off or, per Sinofsky, inevitable."
      }
    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#theAtlantic",
    "@type": [
      "http://schema.org/Organization"
    ],
