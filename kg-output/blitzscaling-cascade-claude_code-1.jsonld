  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#q1",
    "@type": [
      "http://schema.org/Question"
    ],
    "http://schema.org/acceptedAnswer": [
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#a1"
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#faqSection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "What is blitzscaling, and how does it apply to frontier AI labs?"
      }
    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#a3",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Onto the shared computing market: AI firms may be purchasing 70% of the world's high-end memory supply, hard-drive prices rose from $350 to $800 in two years, and US data-center capacity is being expanded roughly eightfold."
      }
    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#a9",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Google, Meta, Microsoft-OpenAI, and xAI optimized within their existing constraints — cloud infrastructure they already owned — rather than questioning whether the scale-up model itself was the right bet."
      }
    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#termDeepSeekShock",
    "@type": [
      "http://schema.org/DefinedTerm",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "The market reaction — including Nvidia's $593 billion single-day loss, the largest in US equity history — to DeepSeek demonstrating comparable model capability at dramatically lower training cost."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "DeepSeek Shock"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#glossarySection"
      }
    ]
  },
  {
