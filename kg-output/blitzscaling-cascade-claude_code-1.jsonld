  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#howtoSection",
    "@type": [
      "http://schema.org/HowTo"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#analysis"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "How to Trace the Blitzscaling-to-Commoditization Cascade"
      }
    ],
    "http://schema.org/step": [
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#step1"
      },
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#step2"
      },
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#step3"
      },
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#step4"
      },
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#step5"
      },
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#step6"
      },
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#step7"
      }
    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#a2",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Blitzscaling normally works because scale lowers unit cost through network effects. Large language models scale quadratically, not logarithmically — each added parameter costs more, not less — inverting the returns blitzscaling depends on."
      }
    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#step5",
    "@type": [
      "http://schema.org/HowToStep"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#howtoSection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Locate the actual binding constraint"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Distinguish the constraint that capital cannot solve — here, electricity/grid capacity — from the one everyone is watching, capital availability."
      }
    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#stevenSinofsky",
    "@type": [
      "http://schema.org/Person"
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Steven Sinofsky"
      }
    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#a12",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Bundling (de-monetizing competitors by folding a capability into an existing platform) and open-sourcing (commoditizing a layer while preserving value in a service built atop it). DeepSeek's commodity-hardware, low-cost approach escapes both, forcing market-wide commoditization instead."
      }
    ]
  },
