      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#a8"
      }
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#faqSection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "How does Steven Sinofsky frame DeepSeek's emergence as inevitable?"
      }
    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#a5",
    "@type": [
      "http://schema.org/Answer"
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Roughly 45% of Microsoft's $625 billion commercial backlog traces to a single customer, OpenAI, which has never generated a profit and is projected to burn $12-15 billion in 2026 operating losses."
      }
    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#termComputeMultiplier",
    "@type": [
      "http://schema.org/DefinedTerm",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Dario Amodei's vaguely defined term for techniques claimed to improve AI model efficiency, without public evidence that quadratic scaling has been solved."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Compute Multiplier"
      }
    ],
