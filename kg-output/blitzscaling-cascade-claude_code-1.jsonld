      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable"
      },
      {
        "@id": "https://shanakaanslemperera.substack.com/p/microsofts-226-billion-shadow"
      }
    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#BlitzscalingBet",
    "@type": [
      "http://www.w3.org/2000/01/rdf-schema#Class"
    ],
    "http://www.w3.org/2000/01/rdf-schema#comment": [
      {
        "@language": "en",
        "@value": "A growth strategy prioritizing speed-to-capability over efficient engineering, assuming efficiency can be retrofitted after scale is captured."
      }
    ],
    "http://www.w3.org/2000/01/rdf-schema#isDefinedBy": [
      {
