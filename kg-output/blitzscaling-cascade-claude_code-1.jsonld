  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#termBlitzscaling",
    "@type": [
      "http://schema.org/DefinedTerm",
      "http://www.w3.org/2004/02/skos/core#Concept"
    ],
    "http://schema.org/description": [
      {
        "@language": "en",
        "@value": "Reid Hoffman and Chris Yeh's growth framework: prioritizing speed over efficiency in winner-take-most markets, assuming efficiency can be retrofitted after scale is captured."
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Blitzscaling"
      }
    ],
    "http://www.w3.org/2004/02/skos/core#inScheme": [
      {
