    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable",
    "@type": [
      "http://schema.org/Article",
      "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#SourceAnalysis"
    ],
    "http://schema.org/about": [
      {
        "@language": "en",
        "@value": "Scale-out commoditization inevitably disrupting hyperscalers' scale-up AI bet, following the historical mainframe-to-mobile pattern."
      }
    ],
    "http://schema.org/author": [
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#stevenSinofsky"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "DeepSeek Has Been Inevitable"
      }
    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#step3",
    "@type": [
      "http://schema.org/HowToStep"
    ],
    "http://schema.org/isPartOf": [
      {
        "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#howtoSection"
      }
    ],
    "http://schema.org/name": [
      {
        "@language": "en",
        "@value": "Trace where the cost lands"
      }
    ],
    "http://schema.org/text": [
      {
        "@language": "en",
        "@value": "Follow the externalized cost onto the shared market — memory supply, hardware prices, data-center buildout — rather than assuming it stays contained to the lab making the bet."
      }
    ]
  },
  {
    "@id": "https://hardcoresoftware.learningbyshipping.com/p/228-deepseek-has-been-inevitable#q8",
    "@type": [
      "http://schema.org/Question"
    ],
