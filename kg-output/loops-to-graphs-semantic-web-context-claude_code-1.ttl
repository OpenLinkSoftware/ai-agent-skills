#################################################################
# Lightweight Ontology
#################################################################

: a owl:Ontology ;
    schema:name "Improvement Architecture & Semantic Web Grounding Ontology"@en ;
    schema:description "A lightweight ontology for modeling self-improvement architectures (loops, graphs of loops, semantic webs of loops), their characteristic failure modes, and the matching Semantic Web constructs that answer them."@en .

:ImprovementPattern a rdfs:Class ;
    rdfs:label "Improvement Pattern"@en ;
    rdfs:comment "An architectural pattern for making a system get better: a single feedback loop, a graph of interconnected loops, or a semantic web of loops grounded in dereferenceable names."@en ;
    rdfs:isDefinedBy : .

:FailureMode a rdfs:Class ;
    rdfs:label "Failure Mode"@en ;
    rdfs:comment "A characteristic way an improvement pattern fails — e.g., Goodhart gaming, reference blindness, loop conflict, measurement decay, circular confirmation."@en ;
    rdfs:isDefinedBy : .

:SemanticWebConstruct a rdfs:Class ;
    rdfs:label "Semantic Web Construct"@en ;
    rdfs:comment "A foundational mechanism of a Semantic Web — dereferenceable IRIs, webby ontologies, verifiable identity, provenance — that supplies grounding an improvement graph cannot generate topologically."@en ;
    rdfs:isDefinedBy : .

:ThesisTest a rdfs:Class ;
    rdfs:label "Thesis Test"@en ;
    rdfs:comment "A pairing of a failure mode identified in the loops-to-graphs literature with its paired Semantic Web construct, plus a verdict on whether the mapping holds."@en ;
    rdfs:isDefinedBy : .

:exhibitsFailureMode a rdf:Property ;
    rdfs:label "exhibits failure mode"@en ;
    rdfs:comment "Relates an improvement pattern to a failure mode it characteristically exhibits."@en ;
    rdfs:domain :ImprovementPattern ;
    rdfs:range :FailureMode ;
    rdfs:isDefinedBy : .

:answeredBy a rdf:Property ;
    rdfs:label "answered by"@en ;
    rdfs:comment "Relates a failure mode to the loop-graph mechanism proposed as its topological answer."@en ;
    rdfs:domain :FailureMode ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy : .

:semanticWebAnalog a rdf:Property ;
    rdfs:label "semantic web analog"@en ;
    rdfs:comment "Relates a failure mode to its paired Semantic Web construct, which answers it by naming and grounding rather than by topology alone."@en ;
    rdfs:domain :FailureMode ;
    rdfs:range :SemanticWebConstruct ;
    rdfs:isDefinedBy : .

:hasVerdict a rdf:Property ;
    rdfs:label "has verdict"@en ;
    rdfs:comment "The outcome of a thesis test: whether the paired Semantic Web construct genuinely answers the failure mode."@en ;
    rdfs:domain :ThesisTest ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy : .

