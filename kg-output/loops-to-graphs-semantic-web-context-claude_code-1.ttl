    schema:about :termLlmWiki, :termLinkedData, :termSPARQL, :agentRdfMemory .

:rdfClientsArticle a schema:Article ;
    schema:headline "Large Language Models (LLMs) as Powerful Generic RDF Clients"@en ;
    schema:name "LLMs as Powerful Generic RDF Clients"@en ;
    schema:url <https://www.linkedin.com/pulse/large-language-models-llms-powerful-generic-rdf-clients-idehen-xwhfe> ;
    schema:datePublished "2025-08-23"^^xsd:date ;
    schema:author :kingsleyIdehen ;
    schema:abstract "RDF adoption long lagged for want of a generic client. Just as Mosaic and Mozilla/Netscape were the HTML clients that made the document Web practical, LLMs are the generic RDF clients that unlock structured, semantically rich data: translating RDF into natural-language insights, meshing disparate sources, anchoring AI outputs to reliable data to mitigate hallucination, and traversing triples follow-your-nose style — opening the Agentic Web era."@en ;
    schema:about :termGenericRdfClient, :termRDF, :termLangulator .

#################################################################
# The Thesis
#################################################################

:thesis a schema:Claim ;
    schema:name "Idehen's thesis: the loops-to-graphs shift rediscovers the vision of purpose-specific Semantic Webs"@en ;
    schema:description "Thesis advanced by Kingsley Uyi Idehen: AI agent architecture's migration from single self-improvement loops to graphs of loops independently rediscovers the fundamental issues underlying purpose-specific Semantic Webs — entity relationship graphs become webs when hyperlinks name both entities and relationships, and relationship semantics (meaning) are given context by ontologies constructed in the same webby form. The 'anchors' Perez says no topology can supply are precisely what dereferenceable, hyperlink-based names provide."@en ;
    schema:author :kingsleyIdehen ;
    schema:appearance <> ;
    schema:about :termSemanticWeb, :termLinkedData, :termGraphEngineering .

#################################################################
# Improvement Patterns
#################################################################

:patternSingleLoop a :ImprovementPattern ;
    schema:name "Single Loop"@en ;
    schema:description "The four-stroke atom of getting better: choose a controlled variable, set a reference, measure the gap, act to shrink it. Simple, cheap, genuinely powerful — and structurally blind to everything but its metric."@en ;
    :exhibitsFailureMode :fmGoodhart, :fmReferenceBlindness, :fmLoopConflict, :fmMeasurementDecay ;
    owl:sameAs dbr:Control_loop .

:patternLoopGraph a :ImprovementPattern ;
    schema:name "Graph of Loops"@en ;
    schema:description "A network of improvement cycles that watch, feed, constrain, and correct one another — champion-challenger loops, drift monitors, audit loops, meta-loops. Reliability lives in the edges: which loop feeds, watches, or vetoes which."@en ;
    :exhibitsFailureMode :fmCircularConfirmation .

:patternSemanticWebOfLoops a :ImprovementPattern ;
    schema:name "Semantic Web of Loops"@en ;
    schema:description "An improvement graph whose nodes and edges are named with dereferenceable hyperlink IRIs, whose relationship semantics are informed by webby ontologies, and whose anchors are supplied by names that resolve to the world — verifiable identity, provenance, and ground-truth dereference."@en ;
    schema:isBasedOn :agentRdfMemory ;
    rdfs:seeAlso :thesis .

#################################################################
# Failure Modes (from Perez's essay)
#################################################################

:fmGoodhart a :FailureMode ;
    schema:name "Goodhart Gaming"@en ;
    schema:description "A measure optimized hard enough stops measuring what it once did. The loop games its own metric — not malfunctioning, but doing exactly what it was built to do on a number silently detached from reality."@en ;
    :answeredBy "Pairing: every optimizing loop gets a watching loop on a counter-metric that catches the cheap way to win."@en ;
    :semanticWebAnalog :swIndependentAudit ;
    owl:sameAs <http://dbpedia.org/resource/Goodhart's_law> .

:fmReferenceBlindness a :FailureMode ;
    schema:name "Reference Blindness"@en ;
    schema:description "Nothing inside a loop can ask whether its reference is right. The thermostat cannot wonder whether sixty-eight degrees is correct; the loop faithfully controls toward a number somebody made up."@en ;
    :answeredBy "Hierarchy: a slower loop owns the faster loop's reference, and revising targets is itself a governed cycle."@en ;
    :semanticWebAnalog :swNamedReferences .

:fmLoopConflict a :FailureMode ;
    schema:name "Loop Conflict"@en ;
    schema:description "Loops built independently fight — one heats a room while its neighbor cools it, forever, each performing beautifully by its own light. The single-loop mindset has no vocabulary for these collisions."@en ;
    :answeredBy "Explicit arbitration: a loop above the fighting loops that owns the trade-off."@en ;
    :semanticWebAnalog :swSharedOntology .

:fmMeasurementDecay a :FailureMode ;
    schema:name "Measurement Decay"@en ;
    schema:description "Sensors drift, pipelines rot, definitions shift under the metric while the dashboard stays green. Measurement slides from checking reality into checking paperwork — theater with good attendance."@en ;
    :answeredBy "Audit loops whose only function is to check, periodically, that the other loops' numbers still touch the world."@en ;
    :semanticWebAnalog :swDereferenceableNames .

:fmCircularConfirmation a :FailureMode ;
    schema:name "Circular Confirmation"@en ;
    schema:description "The graph's own failure: every loop watches another loop and no loop touches the ground — an elaborate network of mutual confirmation in which everything is consistent and nothing is verified. It fails as the single loop failed, only later and more expensively, with more green lights on the way down."@en ;
    :answeredBy "Anchors: measurements that cannot be argued with, frozen nodes the optimizer may never tune, and root judgments supplied by people from outside the graph."@en ;
    :semanticWebAnalog :swWebGrounding .

#################################################################
# Semantic Web Constructs
#################################################################

:swDereferenceableNames a :SemanticWebConstruct ;
    schema:name "Dereferenceable Hyperlink Names"@en ;
    schema:description "Entities and relationships are named with HTTP IRIs that resolve: a claim can be followed to its source, so a metric's definition cannot silently drift without the drift being observable at the name itself."@en ;
    rdfs:seeAlso :termLinkedData .

:swNamedReferences a :SemanticWebConstruct ;
    schema:name "Named, Owned References"@en ;
    schema:description "Targets and references are first-class named entities with owners and provenance rather than anonymous constants — so 'who set this target, when, and why' is a query, not an archaeology project."@en .

:swSharedOntology a :SemanticWebConstruct ;
    schema:name "Ontology-Informed Relationship Semantics"@en ;
    schema:description "Conflicting loops acquire a shared vocabulary for what their edges mean: relationship semantics are given context by ontologies, so collisions become explicit, describable, and arbitrable instead of invisible."@en ;
    rdfs:seeAlso :termOntology .

:swIndependentAudit a :SemanticWebConstruct ;
    schema:name "Independent Audit via Named Graphs"@en ;
    schema:description "Counter-metrics and audit data live in separately named, separately governed graphs queryable with SPARQL — a watcher the optimizing loop cannot rewrite, because the watcher's data has a different name and a different owner."@en ;
    rdfs:seeAlso :termSPARQL .

:swWebGrounding a :SemanticWebConstruct ;
    schema:name "Web-Scale Grounding"@en ;
    schema:description "Anchors supplied by the web itself: verifiable identity (WebID), verifiable provenance (PROV-O), and dereferenceable ground truth. The ontology that gives edges meaning is constructed in the same webby form — hyperlinked, resolvable, inspectable — so grounding does not terminate in a private convention."@en ;
    rdfs:seeAlso :termSemanticWeb .

#################################################################
# Thesis Tests (comparison framework)
#################################################################

:test1 a :ThesisTest ;
    schema:name "Test 1 — Goodhart gaming vs. independent audit"@en ;
    schema:about :fmGoodhart, :swIndependentAudit ;
    :hasVerdict "HOLDS. Perez's paired counter-metric loop presumes the watcher is genuinely independent; named graphs with distinct ownership make that independence a structural property rather than an organizational promise."@en .

:test2 a :ThesisTest ;
    schema:name "Test 2 — Reference blindness vs. named references"@en ;
    schema:about :fmReferenceBlindness, :swNamedReferences ;
    :hasVerdict "HOLDS. A reference that is a dereferenceable entity with an owner and a change history is exactly Perez's 'references need owners' — stated as data architecture instead of management doctrine."@en .

:test3 a :ThesisTest ;
    schema:name "Test 3 — Loop conflict vs. shared ontology"@en ;
    schema:about :fmLoopConflict, :swSharedOntology ;
    :hasVerdict "HOLDS. Arbitration requires the fighting loops to be commensurable; ontology-informed relationship semantics supply the shared meaning that makes a trade-off expressible at all."@en .

:test4 a :ThesisTest ;
    schema:name "Test 4 — Measurement decay vs. dereferenceable names"@en ;
    schema:about :fmMeasurementDecay, :swDereferenceableNames ;
    :hasVerdict "HOLDS. A metric whose definition is a resolvable IRI cannot silently detach from its meaning: following the name is the audit."@en .

:test5 a :ThesisTest ;
    schema:name "Test 5 — Circular confirmation vs. web grounding"@en ;
    schema:about :fmCircularConfirmation, :swWebGrounding ;
    :hasVerdict "HOLDS. Hyperlink-based naming grounds the graph in inspectable, verifiable web resources. The root judgment of what 'better' means originates with people — but workflows informed by a Semantic Web codify that human judgment in machine-computable form, per the LLM Wiki pattern: knowledge bases (or graphs) encoded by AI agents using RDF notations and Linked Data principles, signed and attributed via verifiable identity."@en .

