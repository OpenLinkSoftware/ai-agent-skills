: a owl:Ontology ;
    rdfs:label "Who's Afraid of Chinese Models? — Lightweight Ontology"@en ;
    schema:name "Who's Afraid of Chinese Models? — Lightweight Ontology"@en ;
    schema:description "A small ontology of AI-model economics terms (COGS, token pricing, model classes) used to structure the Knowledge Graph for Ben Thompson's Stratechery article on Chinese open-weight AI models."@en ;
    schema:identifier <https://stratechery.com/2026/whos-afraid-of-chinese-models/> .

:AIModel a rdfs:Class ;
    rdfs:label "AI Model"@en ;
    rdfs:comment "A large language model produced by an AI lab, characterized by parameter count, inference pricing, and cost structure."@en ;
    rdfs:isDefinedBy : .

:OpenWeightModel a rdfs:Class ;
    rdfs:subClassOf :AIModel ;
    rdfs:label "Open Weight Model"@en ;
    rdfs:comment "An AI model whose trained weights are publicly downloadable, allowing self-hosted inference."@en ;
    rdfs:isDefinedBy : .

:FrontierModel a rdfs:Class ;
    rdfs:subClassOf :AIModel ;
    rdfs:label "Frontier Model"@en ;
    rdfs:comment "A closed, state-of-the-art AI model served exclusively by its originating lab via API."@en ;
    rdfs:isDefinedBy : .

:hasParameterCount a rdf:Property ;
    rdfs:label "has parameter count"@en ;
    rdfs:comment "The number of parameters in an AI model, as stated by its maker."@en ;
    rdfs:domain :AIModel ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy : .

:hasInputTokenPrice a rdf:Property ;
    rdfs:label "has input token price"@en ;
    rdfs:comment "The price charged per million input tokens for an AI model's hosted inference API."@en ;
    rdfs:domain :AIModel ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy : .

:hasOutputTokenPrice a rdf:Property ;
    rdfs:label "has output token price"@en ;
    rdfs:comment "The price charged per million output tokens for an AI model's hosted inference API."@en ;
    rdfs:domain :AIModel ;
    rdfs:range xsd:string ;
    rdfs:isDefinedBy : .

#################################################################
# Main Article
#################################################################

:analysis a schema:Article ;
    schema:headline "Who's Afraid of Chinese Models?"@en ;
    schema:name "Who's Afraid of Chinese Models?"@en ;
    schema:description "Everyone is worried about Chinese models, but the frontier labs will be fine; we need to enable open U.S. alternatives."@en ;
    schema:abstract "Ben Thompson argues that panic over Chinese open-weight models like Kimi K3 is economically overblown given today's compute-constrained pricing, but that restricting U.S. defenders' access to frontier models for cybersecurity is a genuine strategic mistake."@en ;
    schema:url <https://stratechery.com/2026/whos-afraid-of-chinese-models/> ;
    schema:datePublished "2026-07-20"^^xsd:date ;
    schema:inLanguage "en" ;
    schema:author <https://www.linkedin.com/in/benjaminjthompson#this> ;
    schema:publisher :stratechery ;
    schema:about dbr:Aggregation_theory, dbr:Open-weight_model, <http://dbpedia.org/resource/Commodity_(economics)>, dbr:Artificial_intelligence ;
    schema:mentions :kimiK3, :qwen38Max, :glm52, :fable, :sol, dbr:Moonshot_AI, dbr:Alibaba_Group, :zai, dbr:Anthropic, dbr:OpenAI, dbr:Nvidia, dbr:Microsoft, dbr:Hugging_Face, :thinkingMachines, dbr:China, dbr:United_States ;
    schema:hasPart :openingAnecdoteSection, :aiModelsSection, :organizationsSection, :peopleSection, :cybersecurityIncidentSection, :faqSection, :glossarySection, :howtoSection, : ;
    prov:wasGeneratedBy <https://github.com/OpenLinkSoftware/ai-agent-skills/tree/main/kg-generator#this> .

:openingAnecdoteSection a schema:CreativeWork ;
    schema:name "Kellogg, Aggregation Theory, and the Return of Marginal Costs"@en ;
    schema:isPartOf :analysis ;
    schema:about dbr:Kellogg_School_of_Management, dbr:Aggregation_theory ;
    schema:hasPart dbr:Kellogg_School_of_Management ;
    schema:text "Thompson recalls that Aggregation Theory rests on the Internet's zero marginal costs, but argues AI is reviving old universal principles: the X debate over Kimi K3 shows marginal costs and industry structure are back in a big way."@en .

